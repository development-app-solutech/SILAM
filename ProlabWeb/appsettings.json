          "connectionString": "Host=65.21.245.245;Port=5432;Database=prolabweb_log;Username=testuser;Password=2025M@dbUsr#@!",
          "tableName": "logs",
          "needAutoCreateTable": true,
          "columnOptionsSection": {
            "message": {
              "ColumnName": "message",
              "RenderMessage": true
            },
            "message_template": { "ColumnName": "message_template" },
            "level": {
              "ColumnName": "level",
              "StoreAsEnum": false
            },
            "raise_date": { "ColumnName": "raise_date" },
            "exception": { "ColumnName": "exception" },
            "properties": {
              "ColumnName": "properties",
              "Format": "Json"
            }
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "ProlabWeb"
    }
