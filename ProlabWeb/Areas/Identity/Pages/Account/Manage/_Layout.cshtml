@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout !=  null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<div class="flex flex-col md:flex-row justify-center items-start min-h-screen bg-gray-50 py-10">
    <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-lg w-full max-w-5xl">
        <div class="w-full md:w-1/3 p-6 border-b md:border-b-0 md:border-r" style="border-color: #e5e7eb; border-right-width: 1px; border-bottom-width: 1px;">
            <partial name="_ManageNav" />
        </div>
        <div class="w-full md:w-2/3 p-8">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
