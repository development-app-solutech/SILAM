@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Changer le mot de passe";
}
<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Changer le mot de passe</h1>
    </div>
    @* <div class="text-end">
        <a asp-page="/Account/Manage/Index" class="text-primary">Retour au profil</a>
    </div> *@
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
            </div>
<div class="min-w-full mb-5">
    <form method="post" class="flex flex-col gap-5 max-w-lg mx-auto">
            <partial name="_StatusMessage" for="StatusMessage" />
        <div asp-validation-summary="ModelOnly" class="text-red-500"></div>
        <div class="flex flex-col gap-3">
            <label class="kt-form-label text-mono" asp-for="Input.OldPassword">Mot de passe actuel</label>
            <input class="kt-input" asp-for="Input.OldPassword" placeholder="Entrer votre mot de passe actuel" type="password" autocomplete="current-password">
            <span asp-validation-for="Input.OldPassword" class="text-red-500"></span>
                </div>
        <div class="flex flex-col gap-3">
            <label class="kt-form-label text-mono" asp-for="Input.NewPassword">Nouveau mot de passe</label>
            <input class="kt-input" asp-for="Input.NewPassword" placeholder="Entrer le nouveau mot de passe" type="password" autocomplete="new-password">
                    <span class="text-gray-400 text-xs">Utilisez 6 caractères ou plus avec un mélange de lettres, chiffres et symboles.</span>
            <span asp-validation-for="Input.NewPassword" class="text-red-500"></span>
                </div>
        <div class="flex flex-col gap-3">
            <label class="kt-form-label text-mono" asp-for="Input.ConfirmPassword">Confirmer le nouveau mot de passe</label>
            <input class="kt-input" asp-for="Input.ConfirmPassword" placeholder="Confirmer le nouveau mot de passe" type="password" autocomplete="new-password">
            <span asp-validation-for="Input.ConfirmPassword" class="text-red-500"></span>
                </div>
        <div class="flex justify-end mt-6 space-x-3">
            <button class="kt-btn kt-btn-primary" type="submit">Enregistrer</button>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}