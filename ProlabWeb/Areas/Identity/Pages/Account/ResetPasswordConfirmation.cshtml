@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Confirmation de réinitialisation du mot de passe";
}
<div class="flex items-center justify-center min-h-[80vh] px-2">
    <div class="w-full max-w-md">
        <div class="kt-card p-6 md:p-8 bg-white rounded-xl shadow-md">
            <div class="text-center mb-8">
                <h1 class="text-2xl font-bold mb-2">Votre mot de passe a été réinitialisé</h1>
                <p class="text-gray-500 mb-6">
                    Votre mot de passe a été réinitialisé avec succès.<br />
                </p>
                <a asp-page="./Login" class="kt-btn kt-btn-primary px-8 py-3 text-lg font-semibold mt-4">Se connecter</a>
            </div>
        </div>
    </div>
</div>
