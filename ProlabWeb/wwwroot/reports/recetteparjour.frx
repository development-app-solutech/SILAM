<Report ScriptLanguage="CSharp" ReportInfo.Created="07/21/2025 11:51:37" ReportInfo.Modified="07/21/2025 17:34:56" ReportInfo.CreatorVersion="2023.3.0.0">
  <Dictionary>
    <PostgresDataConnection Name="Connection" ConnectionString="rijcmlqzIWTAdoF2frcEEZW8+WmSn8EjTWlmxc6XqsWwQ/0mOue9UtI3j17m9xPFWFHNE86lzQXmV2EgGN8QuK86q0p9uA0HdKqB1guSKwBFSA0A7s=">
      <TableDataSource Name="Table" Alias="getdata" DataType="System.Int32" Enabled="true" SelectCommand="SELECT&#13;&#10;    TO_CHAR(datefacture, 'DD/MM/YYYY') as datefacture, entetefactureid, STRING_AGG(traitement, ', ') AS traitements, SUM(prix) AS montant, patientid, nom, prenom, sexe, TO_CHAR(datenaissance, 'DD/MM/YYYY') AS datenaissance&#13;&#10;    &#13;&#10;FROM (&#13;&#10;    (SELECT P.entetefactureid, P.date AS datefacture, p3.categorieid AS id, p3.nom AS traitement, p6.prix, p4.patientid, p4.nom, p4.prenom, p5.value AS sexe, p4.datenaissance&#13;&#10;	FROM public.&quot;entetefacture&quot; P, public.&quot;entetedemande&quot; p1, public.&quot;detailfacture&quot; p2, public.&quot;categorie&quot; p3, public.&quot;patient&quot; p4, public.&quot;sexe&quot; p5, public.&quot;detaildemande&quot; p6&#13;&#10;	WHERE DATE(P.date)=DATE(@datefacture1) &#13;&#10;	AND p4.codesexe = p5.codesexe &#13;&#10;	AND P.entetedemandeid = p1.entetedemandeid &#13;&#10;	AND p4.patientid = p1.patientid &#13;&#10;	AND P.entetefactureid = p2.entetefactureid &#13;&#10;	AND p2.detaildemandeid = p6.detaildemandeid &#13;&#10;	AND p6.categorieid = p3.categorieid &#13;&#10;	AND p6.entetedemandeid = p1.entetedemandeid)&#13;&#10;	&#13;&#10;    UNION all&#13;&#10;    &#13;&#10;    (SELECT P.entetefactureid, P.date AS datefacture, p6.idanalyse AS id, p6.nom AS traitement, p5.prix, p3.patientid, p3.nom, p3.prenom, p4.value AS sexe, p3.datenaissance&#13;&#10;	FROM public.&quot;entetefacture&quot; P, public.&quot;detailfacture&quot; p1, public.&quot;entetedemande&quot; p2, public.&quot;patient&quot; p3, public.&quot;sexe&quot; p4, public.&quot;detaildemande&quot; p5, public.&quot;analyse&quot; p6&#13;&#10;	WHERE DATE(P.date)=DATE(@datefacture2) &#13;&#10;	AND p3.codesexe = p4.codesexe &#13;&#10;	AND P.entetefactureid = p1.entetefactureid &#13;&#10;	AND P.entetedemandeid = p2.entetedemandeid &#13;&#10;	AND p3.patientid = p2.patientid &#13;&#10;	AND p1.detaildemandeid = p5.detaildemandeid &#13;&#10;	AND p5.idanalyse = p6.idanalyse&#13;&#10;	AND p2.entetedemandeid = p5.entetedemandeid)&#13;&#10;) sub&#13;&#10;GROUP BY datefacture, patientid, nom, prenom, sexe, datenaissance, entetefactureid&#13;&#10;">
        <Column Name="entetefactureid" DataType="System.String"/>
        <Column Name="patientid" DataType="System.String"/>
        <Column Name="nom" DataType="System.String"/>
        <Column Name="sexe" DataType="System.String"/>
        <Column Name="datenaissance" DataType="System.String"/>
        <Column Name="traitements" DataType="System.String"/>
        <Column Name="prenom" DataType="System.String"/>
        <Column Name="montant" DataType="System.String"/>
        <Column Name="datefacture" DataType="System.String"/>
        <CommandParameter Name="datefacture1" DataType="7" Expression="[datefacture]"/>
        <CommandParameter Name="datefacture2" DataType="7" Expression="[datefacture]"/>
      </TableDataSource>
    </PostgresDataConnection>
    <Parameter Name="operateur" DataType="System.String" AsString=""/>
    <Parameter Name="datefacture" DataType="System.String" AsString=""/>
  </Dictionary>
