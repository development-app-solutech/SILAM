  <Dictionary>
    <PostgresDataConnection Name="Connection" ConnectionString="rijcmlqzIWTAdoF2frcEEZW8+WmSn8EjTWlmxc6XqsWwQ/0mOue9UtI3j17m9xPFWFHNE86lzQXmV2EgGN8QuK86q0p9uA0HdKqB1guSKwBFSA0A7s=">
      <TableDataSource Name="Table" Alias="getanalyses" DataType="System.Int32" Enabled="true" SelectCommand="SELECT DISTINCT p6.idanalyse, p6.nom&#13;&#10;FROM public.&quot;entetefacture&quot; P, public.&quot;entetedemande&quot; p1, public.&quot;detailfacture&quot; p2, public.&quot;detaildemande&quot; p3, public.&quot;categorie&quot; p4, public.&quot;categorieanalyse&quot; p5, public.&quot;analyse&quot; p6&#13;&#10;WHERE P.entetefactureid=CAST(@factureid1 AS UUID) AND P.entetedemandeid = p1.entetedemandeid AND P.entetefactureid = p2.entetefactureid AND p2.detaildemandeid = p3.detaildemandeid AND p3.categorieid = p4.categorieid AND p4.categorieid = p5.categorieid AND p5.idanalyse = p6.idanalyse&#13;&#10;UNION ALL&#13;&#10;(SELECT DISTINCT p6.idanalyse, p6.nom&#13;&#10;FROM public.&quot;entetefacture&quot; P, public.&quot;entetedemande&quot; p1, public.&quot;detailfacture&quot; p2, public.&quot;detaildemande&quot; p3, public.&quot;analyse&quot; p6&#13;&#10;WHERE P.entetefactureid=CAST(@factureid2 AS UUID) AND P.entetedemandeid = p1.entetedemandeid AND P.entetefactureid = p2.entetefactureid AND p2.detaildemandeid = p3.detaildemandeid AND p3.idanalyse = p6.idanalyse)&#13;&#10;">
        <Column Name="nom" DataType="System.String"/>
        <Column Name="idanalyse" DataType="System.String"/>
        <CommandParameter Name="factureid1" DataType="22" Expression="[factureid]"/>
        <CommandParameter Name="factureid2" DataType="22" Expression="[factureid]"/>
      </TableDataSource>
    </PostgresDataConnection>
