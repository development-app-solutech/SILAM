<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="07/09/2025 11:27:41" ReportInfo.Modified="07/23/2025 18:19:04" ReportInfo.CreatorVersion="2023.3.0.0">
  <Dictionary>
    <PostgresDataConnection Name="Connection" ConnectionString="rijcmlqzIWTAdoF2frcEEZW8+WmSn8EjTWlmxc6XqsWwQ/0mOue9UtI3j17m9xPFWFHNE86lzQXmV2EgGN8QuK86q0p9uA0HdKqB1guSKwBFSA0A7s=">
      <TableDataSource Name="Table" Alias="getdata" DataType="System.Int32" Enabled="true" SelectCommand="SELECT TO_CHAR(date, 'DD/MM/YYYY') AS date, id, nom, nbre, prix, montant, CAST((montant*0.20) AS NUMERIC(20,2)) AS remise &#13;&#10;FROM &#13;&#10;(&#13;&#10;(SELECT DISTINCT ON(p3.categorieid) P.date, p3.categorieid AS id, p3.nom, COUNT(p3.categorieid) as nbre, p2.prix, (COUNT(p3.categorieid)*p2.prix) AS montant, p2.partassurance, p2.partpatient, p2.complement, p2.net, p4.codeassurance, p4.nom AS assurance&#13;&#10;FROM public.&quot;entetefacture&quot; P, public.&quot;entetedemande&quot; p1, public.&quot;detaildemande&quot; p2, public.&quot;categorie&quot; p3, public.&quot;assurance&quot; p4, public.&quot;policeassurance&quot; p5&#13;&#10;WHERE DATE(P.date) &gt;= DATE(@datedebut1) AND DATE(P.date) &lt;= DATE(@datefin1) AND p4.codeassurance=@codeassurance1 AND P.entetedemandeid = p1.entetedemandeid AND p1.entetedemandeid = p2.entetedemandeid AND p1.policeassuranceid = p5.policeassuranceid AND p5.codeassurance = p4.codeassurance AND p3.categorieid = p2.categorieid&#13;&#10;GROUP BY P.date, p3.categorieid, p3.nom, p2.prix, p2.partassurance, p2.partpatient, p2.complement, p2.net, p4.codeassurance, p4.nom)&#13;&#10;&#13;&#10;UNION ALL &#13;&#10;&#13;&#10;(select DISTINCT ON(p3.idanalyse) P.date, p3.idanalyse AS id, p3.nom, COUNT(p3.idanalyse) AS nbre, p2.prix, (COUNT(p3.idanalyse)*(p2.prix)) as montant, p2.partassurance, p2.partpatient, p2.complement, p2.net, p5.codeassurance, p5.nom AS assurance&#13;&#10;FROM public.&quot;entetefacture&quot; P, public.&quot;entetedemande&quot; p1, public.&quot;detaildemande&quot; p2, public.&quot;analyse&quot; p3, public.&quot;policeassurance&quot; p4, public.&quot;assurance&quot; p5&#13;&#10;WHERE DATE(P.date) &gt;= DATE(@datedebut2) AND DATE(P.date) &lt;= DATE(@datefin2) AND p5.codeassurance=@codeassurance2 AND p2.idanalyse = p3.idanalyse AND p2.entetedemandeid = p1.entetedemandeid AND P.entetedemandeid = p1.entetedemandeid AND p1.policeassuranceid = p4.policeassuranceid AND p5.codeassurance = p4.codeassurance&#13;&#10;GROUP BY P.date, p3.idanalyse, p3.nom, p2.prix, p2.partassurance, p2.partpatient, p2.complement, p2.net, p5.codeassurance, p5.nom)&#13;&#10;) sub&#13;&#10;ORDER BY date DESC &#13;&#10;">
        <Column Name="nom" DataType="System.String"/>
        <Column Name="date" DataType="System.String"/>
        <Column Name="id" DataType="System.String"/>
        <Column Name="nbre" DataType="System.String"/>
        <Column Name="prix" DataType="System.String"/>
        <Column Name="remise" DataType="System.String"/>
        <Column Name="montant" DataType="System.String"/>
        <CommandParameter Name="datedebut1" DataType="7" Expression="[datedebut]"/>
        <CommandParameter Name="datefin1" DataType="7" Expression="[datefin]"/>
        <CommandParameter Name="codeassurance1" DataType="22" Expression="[codeassurance]"/>
        <CommandParameter Name="datedebut2" DataType="7" Expression="[datedebut]"/>
        <CommandParameter Name="datefin2" DataType="7" Expression="[datefin]"/>
        <CommandParameter Name="codeassurance2" DataType="22" Expression="[codeassurance]"/>
      </TableDataSource>
    </PostgresDataConnection>
    <Parameter Name="datedebut" DataType="System.String" AsString=""/>
    <Parameter Name="datefin" DataType="System.String" AsString=""/>
    <Parameter Name="codeassurance" DataType="System.String" AsString=""/>
