    <Parameter Name="sommetotal" DataType="System.String" AsString=""/>
    <Parameter Name="sommeremise" DataType="System.String" AsString=""/>
    <Parameter Name="montantnet" DataType="System.String" AsString=""/>
    <Parameter Name="sommenet" DataType="System.String" AsString=""/>
    <Parameter Name="montanttotal" DataType="System.String" AsString=""/>
