@model IEnumerable<ProlabWeb.Db.Entetefacture>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Date)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Numero)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Caisse)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Utilisateur)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Entetedemande)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Numero)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Caisse.Caisseid)
            </td>
            <td>
                    @Html.DisplayFor(modelItem => item.Utilisateur.Utilisateurid)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Entetedemande.Entetedemandeid)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Entetefactureid">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Entetefactureid">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Entetefactureid">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
