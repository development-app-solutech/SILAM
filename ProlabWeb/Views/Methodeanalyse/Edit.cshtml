@model ProlabWeb.Db.Methodeanalyse

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Methodeanalyse</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Idanalyse" class="control-label"></label>
                <select asp-for="Idanalyse" class="form-control" asp-items="ViewBag.Idanalyse"></select>
                <span asp-validation-for="Idanalyse" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Idmethode" class="control-label"></label>
                <select asp-for="Idmethode" class="form-control" asp-items="ViewBag.Idmethode"></select>
                <span asp-validation-for="Idmethode" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Isdefaultmethode" /> @Html.DisplayNameFor(model => model.Isdefaultmethode)
                </label>
            </div>
            <input type="hidden" asp-for="Methodeanalyseid" />
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
