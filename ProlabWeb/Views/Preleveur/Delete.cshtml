@model ProlabWeb.Db.Preleveur

@{
    ViewData["Title"] = "Supprimer un préleveur";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
<div>
        <h1 class="font-bold text-red-600">Supprimer un préleveur</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <div class="flex items-center gap-4 mb-6" style="background:#fee2e2; border:1.5px solid #dc2626; color:#b91c1c; border-radius:0.5rem; padding:1rem;">
        <span class="material-symbols-outlined text-4xl" style="color:#dc2626;">warning</span>
        <div style="color:#b91c1c; font-size:1.125rem; font-weight:600;">
            Êtes-vous vraiment sûr de vouloir supprimer ce préleveur ?<br />
            Cette action est <span class="font-bold">irréversible</span>.
        </div>
    </div>
    <div class="mt-6"></div>
    <div class="bg-gray-50 p-4 rounded-lg mb-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Résumé du préleveur</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="flex flex-col gap-3">
                <div><span class="font-semibold">Nom :</span> @Model.Nom</div>
                <div><span class="font-semibold">Prénom :</span> @Model.Prenom</div>
                <div><span class="font-semibold">Sexe :</span> @Model.CodesexeNavigation?.Codesexe</div>
                <div><span class="font-semibold">Date de naissance :</span> @Model.Datenaissance</div>
                <div><span class="font-semibold">Type :</span> @Model.Fonction</div>
            </div>
            <div class="flex flex-col gap-3">
                <div><span class="font-semibold">Téléphone 1 :</span> @Model.Tel1</div>
                <div><span class="font-semibold">Téléphone 2 :</span> @Model.Tel2</div>
                <div><span class="font-semibold">Mobile 1 :</span> @Model.Mob1</div>
                <div><span class="font-semibold">Mobile 2 :</span> @Model.Mob2</div>
                <div><span class="font-semibold">Email :</span> @Model.Email</div>
            </div>
        </div>
    </div>
    <form asp-action="Delete" method="post" class="flex flex-col gap-5">
        <input type="hidden" asp-for="Preleveurid" />
        <div class="flex justify-end mt-6 space-x-3">
            <a asp-action="Index" class="kt-btn kt-btn-outline mr-4">Annuler</a>
            <button type="submit" class="kt-btn kt-btn-primary bg-red-600 hover:bg-red-700 border-none">Supprimer</button>
        </div>
    </form>
</div>
