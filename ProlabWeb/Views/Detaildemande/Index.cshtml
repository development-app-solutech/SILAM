@model IEnumerable<ProlabWeb.Db.Detaildemande>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Categorie)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Entetedemande)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdanalyseNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Categorie.Categorieid)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Entetedemande.Entetedemandeid)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdanalyseNavigation.Idanalyse)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Detaildemandeid">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Detaildemandeid">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Detaildemandeid">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
