 *@

<div class="grid grid-cols-2 gap-5">
    <div>
        <h1 class="font-bold">Modification Tarif assurance pour analyse</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour ŕ liste</a>
    </div>
</div>
<div class="flex items-center gap-2">
    <span class="border-t border-border border-primary w-full">
    </span>
</div>

<div class="min-w-full mb-5">

    <form asp-action="Edit" class="flex flex-col gap-5" id="" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-red-500"></div>
        <input type="hidden" name="Codeassurance" value="@Model.Codeassurance" />
        <div class="grid gap-5">
            <div class="flex flex-col gap-5">
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono">Assurance</label>
                    <select class="kt-select w-100 js-example-basic-single" asp-items="@ViewBag.Codeassurance" disabled>
                    </select>
                </div>
            </div>
            <div class="flex flex-col gap-3">
                <label class="kt-form-label text-mono">Laboratoire</label>
                <select class="kt-select w-100 js-example-basic-single" name="Idlaboratoire" asp-items="@ViewBag.Idlaboratoire">
                </select>
            </div>

            <div class="grid gap-5" >
                <div class="grid gap-5" style="row-gap: 1rem;">
                    <div>
                        <label class="kt-input border-t border-primary">
                            <span class="material-symbols-outlined">
                                search
                            </span>
                            <input class="kt-input" placeholder="Recherche" type="text" data-kt-tarifanalyseassurance-table-filter="search">
                        </label>
                    </div>
                </div>
                <div class="kt-scrollable-x-auto">
                    <table id="kt_table_tarifanalyseassurance_edit" class="kt-table table-auto kt-table-border">
                        <thead>
                            <tr>
                                <th>
                                    <span class="kt-table-col">
                                        <span class="kt-table-col-label">
                                            Analyse
                                        </span>
                                    </span>
                                </th>
                                <th>
                                    <span class="kt-table-col">
                                        <span class="kt-table-col-label">
                                            Prix
                                        </span>
                                    </span>
                                </th>
                            </tr>
                        </thead>

                        <div id="kt_spinner_tarifanalyseassurance_edit" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" style="display: none;">
                            <div class="kt-datatable-loading">
                                <svg class="animate-spin -ml-1 h-5 w-5 text-gray-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                Loading...
                            </div>
                        </div>

                        <tbody>
                            @for (var i = 0; i < Model.Tarif.Count; i++)
                            {
                                <tr>
                                    <td class="font-normal text-foreground">
                                        <input hidden type="text" name="Tarif[@i].Idanalyse" value="@Model.Tarif[i].Idanalyse" />
                                        <input hidden type="text" name="Tarif[@i].Nom" value="@Model.Tarif[i].Nom" />
                                        <span>@Model.Tarif[i].Nom</span>
                                    </td>
                                    <td class="font-normal text-foreground">
                                        <input class="kt-input" name="Tarif[@i].Prix" placeholder="" type="number" step="0.01" value="@Model.Tarif[i].Prix">
                                        <span asp-validation-for="Tarif[@i].Prix" class="text-destructive"></span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="inline-flex justify-start grow">
                <button type="submit" class="kt-btn kt-btn-primary">
                    <span class="material-symbols-outlined">
                        save
                    </span> Enregistrer
                </button>
            </div>
        </div>
    </form>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function(){

            KTTarifanalyseassuranceEdit.init();

            $('.js-example-basic-single').select2({
                // theme: "classic",
                width: '100%'
            });
        })
    </script>
}
