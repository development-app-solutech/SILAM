@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function() {
            var defaultImage = '/img/photo_patient_default.png';

            function calculerAgeDepuisDate(dateStr) {
                if (!dateStr) return '';

                const birthDate = new Date(dateStr);
                if (isNaN(birthDate.getTime())) return '';

                const today = new Date();
                let age = today.getFullYear() - birthDate.getFullYear();
                const monthDiff = today.getMonth() - birthDate.getMonth();

                if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
                    age--;
                }

                if (age < 0) return '';
                return age;
            }

            function setDefaultImage() {
                $('#imgImage').attr('src', defaultImage);
                $('[name="File"]').val('');
                $('[name="Filename"]').val('');
            }

            $('#btnSelectImage').on('click', function(e) {
                e.preventDefault();
                $('[name="File"]').click();
            });

            $('[name="File"]').on('change', function (event) {
                const file = event.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imgImage').attr('src', e.target.result); // Set image preview
                        $('[name="Filename"]').val(file.name);
                    };
                    reader.readAsDataURL(file);
                }
            });

            $('#imgImage').on('error', function () {
                setDefaultImage();
            });

            $('#btnCancelImage').on('click', function (e) {
                e.preventDefault();
                setDefaultImage();
            });

            $('.js-example-basic-single').select2({
                // theme: "classic",
                width: '100%'
            });

            $('.summernote').summernote({
                placeholder: '',
                tabsize: 2,
                height: 120,
                toolbar: [
                ['style', ['style']],
                ['font', ['bold', 'underline', 'clear']],
                ['color', ['color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['table', ['table']],
                ['insert', ['link', 'picture', 'video']],
                ['view', ['fullscreen', 'codeview', 'help']]
                ]
            });

            $('[name="Datenaissance"]').on('change', function() {
                const age = calculerAgeDepuisDate($(this).val());
                if (age !== '') {
                    $('[name="Age"]').val(age);
                }
            });

            if (!$('[name="Age"]').val() && $('[name="Datenaissance"]').val()) {
                const age = calculerAgeDepuisDate($('[name="Datenaissance"]').val());
                if (age !== '') {
                    $('[name="Age"]').val(age);
                }
            }

        });
    </script>

}
