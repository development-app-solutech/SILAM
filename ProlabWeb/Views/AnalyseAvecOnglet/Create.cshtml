        <!-- Onglet Tarif assurance -->
        <div id="content-tarifs" class="tab-content hidden">
            <div class="mb-4">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-lg font-semibold">Tarifs assurance</h3>
                </div>
                <div class="kt-scrollable-x-auto">
                    <table class="kt-table table-auto kt-table-border min-w-full" id="tarifsTable">
                        <thead>
                            <tr>
                                <th style="min-width: 250px !important; width: 50% !important;"><span class="kt-table-col-label font-bold">Assurance</span></th>
                                <th style="min-width: 250px !important; width: 50% !important;"><span class="kt-table-col-label font-bold">Prix</span></th>
                            </tr>
                        </thead>
                        <tbody id="tarifsTableBody">
                            @if (Model.TarifsAssurance != null && Model.TarifsAssurance.Any())
                            {
                                var count = Model.TarifsAssurance.Count;
                                for (int i = 0; i < count; i++)
                                {
                                    <tr>
                                        <input type="hidden" asp-for="TarifsAssurance[@i].Codeassurance" />
                                        <input type="hidden" asp-for="TarifsAssurance[@i].Nom" />
                                        <td>
                                            <span class="assurance-name">@Model.TarifsAssurance[i].Nom</span>
                                        </td>
                                        <td>
                                            <input asp-for="TarifsAssurance[@i].Prix" class="kt-input w-100" type="number" />
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Bouton d'enregistrement (commun à tous les onglets) -->
        <div class="mt-6">
            <div class="inline-flex justify-start grow">
                <button type="submit" class="kt-btn kt-btn-primary">
                    <span class="material-symbols-outlined">
                        save
                    </span> Enregistrer
                </button>
            </div>
        </div>
    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const typeParametresOptions = @Html.Raw(Json.Serialize(ViewBag.TypeParametres));
        const sexeOptions = @Html.Raw(Json.Serialize(ViewBag.Sexeautorisecode));
        const codeUniteOptions = @Html.Raw(Json.Serialize(ViewBag.Codeunite));
        const codeUniteSiOptions = @Html.Raw(Json.Serialize(ViewBag.Codeunitesi));
    </script>

    @* -------------------------- script pour parametre ------------------------------- *@

    <script>
        $(function() {

            let parametreIndex = 0;

            function generateSelectOptions(options) {
                let html = '';
                for (let i = 0; i < options.length; i++) {
                    html += `<option value="${options[i].value}">${options[i].text}</option>`;
                }
                return html;
            }

            function reindexRowsParametre() {
                $('#parametresTableBody tr').each(function (rowIndex, row) {
                    $(row).find('input, select, textarea, label, div').each(function () {
                        const $el = $(this);

                        $.each(['name', 'id', 'for'], function (_, attr) {
                            const val = $el.attr(attr);
                            if (val && val.includes('Parametres[')) {
                                const newVal = val.replace(/Parametres\[\d+\]/g, `Parametres[${rowIndex}]`);
                                $el.attr(attr, newVal);
                            }
                        });

                        // Ajuster l'id spécifique pour divValeur_#
                        if ($el.attr('id') && $el.attr('id').startsWith('divValeur_')) {
                            $el.attr('id', `divValeur_${rowIndex}`);
                        }
                        if ($el.attr('id') && $el.attr('id').startsWith('selectType_')) {
                            $el.attr('id', `selectType_${rowIndex}`);
                        }
                    });
                });

                parametreIndex = $('#parametresTableBody tr').length;
            }

            function createParametreRow(index) {
                return `
                <tr>
                    <td>
                        <textarea class="kt-input w-100" name="Parametres[${index}].Nom" id="Parametres[${index}].Nom" placeholder="" style="height: 6em; line-height: 1.5em;"></textarea>
                    </td>
                    <td>
                        <input name="Parametres[${index}].Code" id="Parametres[${index}].Code" class="kt-input w-100" />
                    </td>
                    <td class="text-center">
                        <input type="checkbox" name="Parametres[${index}].Masquer" id="Parametres[${index}].Masquer" class="form-check-input" />
                    </td>
                    <td>
                        <div class="flex flex-col gap-3">
                            <div class="flex flex-col gap-3">
                                <label class="kt-form-label text-mono" for="Parametres[${index}].Builder.Type">Type</label>
                                <select id="selectType_${index}" name="Parametres[${index}].Builder.Type" class="kt-select w-100 js-example-basic-single">
                                    ${generateSelectOptions(typeParametresOptions)}
                                </select>
                            </div>
                            <div id="divValeur_${index}" class="flex flex-col gap-3" style="display: none;">
                                <label class="kt-form-label text-mono" for="Parametres[${index}].Builder.Valeur">Valeur</label>
                                <textarea class="kt-input w-100" name="Parametres[${index}].Builder.Valeur" id="Parametres[${index}].Builder.Valeur" placeholder="" style="height: 6em; line-height: 1.5em;"></textarea>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="flex flex-col gap-3">
                            <input name="Parametres[${index}].ResultatStandard" id="Parametres[${index}].ResultatStandard" class="kt-input w-100" />
                            <select name="Parametres[${index}].UniteStandard" id="Parametres[${index}].UniteStandard" class="kt-select w-100 js-example-basic-single">
                                ${generateSelectOptions(codeUniteOptions)}
                            </select>
                        </div>
                    </td>
                    <td>
                        <div class="flex flex-col gap-3">
                            <input name="Parametres[${index}].ResultatSI" id="Parametres[${index}].ResultatSI" class="kt-input w-100" />
                            <select name="Parametres[${index}].UniteSI" id="Parametres[${index}].UniteSI" class="kt-select w-100 js-example-basic-single">
                                ${generateSelectOptions(codeUniteSiOptions)}
                            </select>
                        </div>
                    </td>
                    <td>
                        <input name="Parametres[${index}].FacteurConversion" id="Parametres[${index}].FacteurConversion" class="kt-input w-100" />
                    </td>
                    <td>
                        <input type="number" name="Parametres[${index}].OrdreAffichage" id="Parametres[${index}].OrdreAffichage" class="kt-input w-100" />
                    </td>
                </tr>`;
            }

            // Add button
            $('#addParametre').on('click', function () {
                const newRow = createParametreRow(parametreIndex);
                $('#parametresTableBody').append(newRow);

                $('.js-example-basic-single').select2();

                reindexRowsParametre();
                handlerZoneBuilder();
            });

            // Remove button
            $('#removeParametre').on('click', function () {
                const $rows = $('#parametresTableBody tr');
                if ($rows.length === 0) return;

                $rows.last().remove();
                reindexRowsParametre();
                handlerZoneBuilder();
            });

            handlerZoneBuilder();

            function handlerZoneBuilder() {
                const parametreCount = $('#parametresTableBody tr').length;

                for (let i = 0; i < parametreCount; i++) {

                    console.log(i);

                    $(`#selectType_${i}`).on('change', function() {

                        var type = $(`#selectType_${i}`).val();

                        console.log(type);
                        console.log(i);

                        if (type === 'Texte') {

                            hideDivValeur(i);
                        } else if (type === 'Liste') {

                            showDivValeur(i);
                        } else if (type === 'Formule') {

                            showDivValeur(i);
                        }
                    })
                    .trigger('change');
                }
            }

            function showDivValeur(i) {
                $(`#divValeur_${i}`).show();
            }

            function hideDivValeur(i) {
                $(`#divValeur_${i}`).hide();
            }

        })
    </script>

    @* ----------------------------- script pour valeur reference ------------------------------- *@

    <script>
        $(function () {

            let referenceIndex = 0;

            function generateSelectOptions(options) {
                let html = '';
                for (let i = 0; i < options.length; i++) {
                    html += `<option value="${options[i].value}">${options[i].text}</option>`;
                }
                return html;
            }

            function createValeurReferenceRow(i) {
                const rowHtml = `
                    <tr>
                        <td>
                            <div class="flex flex-col gap-3">
                                <select class="kt-select w-100 js-example-basic-single"
                                        name="ValeursReference[${i}].Sexeautorisecode"
                                        id="ValeursReference[${i}].Sexeautorisecode">
                                    ${generateSelectOptions(sexeOptions)}
                                </select>
                            </div>
                        </td>
                        <td>
                            <div class="flex flex-col gap-3">
                                <input class="kt-input" type="number"
                                       name="ValeursReference[${i}].Agedebut"
                                       id="ValeursReference[${i}].Agedebut" />
                                <select class="kt-select w-100 js-example-basic-single"
                                        name="ValeursReference[${i}].Codeunitagedebut"
                                        id="ValeursReference[${i}].Codeunitagedebut">
                                    ${generateSelectOptions(codeUniteOptions)}
                                </select>
                            </div>
                        </td>
                        <td>
                            <div class="flex flex-col gap-3">
                                <input class="kt-input" type="number"
                                       name="ValeursReference[${i}].Agefin"
                                       id="ValeursReference[${i}].Agefin" />
                                <select class="kt-select w-100 js-example-basic-single"
                                        name="ValeursReference[${i}].Codeunitagefin"
                                        id="ValeursReference[${i}].Codeunitagefin">
                                    ${generateSelectOptions(codeUniteOptions)}
                                </select>
                            </div>
                        </td>
                        <td>
                            <div class="flex flex-col gap-3">
                                <input class="kt-input" type="text"
                                       name="ValeursReference[${i}].Titre"
                                       id="ValeursReference[${i}].Titre" />
                            </div>
                        </td>
                        <td>
                            <div class="flex flex-col gap-3">
                                <div class="grid grid-cols-2 gap-5" style="row-gap:1rem;">
                                    <input class="kt-input" type="number"
                                           name="ValeursReference[${i}].Referencefromvalue"
                                           id="ValeursReference[${i}].Referencefromvalue" />
                                    <input class="kt-input" type="number"
                                           name="ValeursReference[${i}].Referencetovalue"
                                           id="ValeursReference[${i}].Referencetovalue" />
                                </div>
                                <select class="kt-select w-100 js-example-basic-single"
                                        name="ValeursReference[${i}].Codeunitreference"
                                        id="ValeursReference[${i}].Codeunitreference">
                                    ${generateSelectOptions(codeUniteOptions)}
                                </select>
                            </div>
                        </td>
                        <td>
                            <div class="flex flex-col gap-3">
                                <div class="grid grid-cols-2 gap-5" style="row-gap:1rem;">
                                    <input class="kt-input" type="number"
                                           name="ValeursReference[${i}].Referencefromvaluesi"
                                           id="ValeursReference[${i}].Referencefromvaluesi" />
                                    <input class="kt-input" type="number"
                                           name="ValeursReference[${i}].Referencetovaluesi"
                                           id="ValeursReference[${i}].Referencetovaluesi" />
                                </div>
                                <select class="kt-select w-100 js-example-basic-single"
                                        name="ValeursReference[${i}].Codeunitreferencesi"
                                        id="ValeursReference[${i}].Codeunitreferencesi">
                                    ${generateSelectOptions(codeUniteSiOptions)}
                                </select>
                            </div>
                        </td>
                    </tr>
                `;

                return rowHtml;
            }

            function reindexRowsValeurReference() {
                $('#referencesTableBody tr').each(function (rowIndex, row) {
                    $(row).find('input, select').each(function () {
                        const name = $(this).attr('name');
                        if (!name) return;

                        const newName = name.replace(/ValeursReference\[\d+\]/, `ValeursReference[${rowIndex}]`);
                        $(this).attr('name', newName);
                        $(this).attr('id', newName);
                    });
                });

                referenceIndex = $('#referencesTableBody tr').length;
            }

            $('#removeReference').on('click', function () {
                const $rows = $('#referencesTableBody tr');
                if ($rows.length === 0) return;

                // Supprime la dernière ligne
                $rows.last().remove();

                // Réindexe tous les champs
                reindexRowsValeurReference();
            });

            document.getElementById('addReference').addEventListener('click', function () {
                const i = referenceIndex;
                const rowHtml = createValeurReferenceRow(i);

                document.getElementById('referencesTableBody').insertAdjacentHTML('beforeend', rowHtml);

                // Initialisation Select2 sur les nouveaux <select>
                $('.js-example-basic-single').select2();

                reindexRowsValeurReference();
            });

        });

    </script>

    <script>
        $(document).ready(function() {

            $('.js-example-basic-single').select2({
                // theme: "classic",
                width: '100%'
            });

            $('.js-example-basic-multiple').select2({
                // theme: "classic",
                width: '100%'
            });

            $('.summernote').summernote({
                placeholder: '',
                tabsize: 2,
                height: 120,
                toolbar: [
                ['style', ['style']],
                ['font', ['bold', 'underline', 'clear']],
                ['color', ['color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['table', ['table']],
                ['insert', ['link', 'picture', 'video']],
                ['view', ['fullscreen', 'codeview', 'help']]
                ]
            });

            // Gestion des onglets
            initializeTabs();
            
        });

        // Fonction pour initialiser la navigation des onglets
        function initializeTabs() {
            $('.tab-button').click(function() {
                const targetTab = $(this).attr('id').replace('tab-', 'content-');
                
                // Mettre à jour l'apparence des boutons d'onglets
                $('.tab-button').removeClass('active border-primary text-primary')
                    .addClass('border-transparent text-gray-500');
                $(this).removeClass('border-transparent text-gray-500')
                    .addClass('active border-primary text-primary');
                
                // Afficher/masquer le contenu des onglets
                $('.tab-content').addClass('hidden');
                $('#' + targetTab).removeClass('hidden');
            });
        }

    </script>
}
