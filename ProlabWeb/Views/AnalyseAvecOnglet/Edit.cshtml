                    alert('ERREUR: Options d\'unités non disponibles. Veuillez rafraîchir la page.');
                    return;
                }
                
                if (typeof codeUniteSiOptions === 'undefined' || !Array.isArray(codeUniteSiOptions)) {
                    console.error('[DEBUG] codeUniteSiOptions is not defined or not an array');
                    alert('ERREUR: Options d\'unités SI non disponibles. Veuillez rafraîchir la page.');
                    return;
                }
                
                if (typeof currentAnalyseId === 'undefined' || !currentAnalyseId) {
                    console.error('[DEBUG] currentAnalyseId is not defined');
                    alert('ERREUR: ID d\'analyse manquant. Veuillez rafraîchir la page.');
                    return;
                }
                
                console.log(`[DEBUG] All required variables validated successfully`);
                
                try {
                    // Use current referenceIndex for new row
                    const i = referenceIndex;
                    const rowElement = createValeurReferenceRow(i);
                    
                    // Validate the row was created successfully
                    if (!rowElement || rowElement.tagName !== 'TR') {
                        throw new Error('Failed to create table row element');
                    }
                    
                    // Count expected fields in the new row
                    const expectedFields = [
                        'Valeurreferenceid', 'Idanalyse', 'Sexeautorisecode',
                        'Agedebut', 'Codeunitagedebut', 'Agefin', 'Codeunitagefin',
                        'Titre', 'Referencefromvalue', 'Referencetovalue', 'Codeunitreference',
                        'Referencefromvaluesi', 'Referencetovaluesi', 'Codeunitreferencesi'
                    ];
                    
                    let actualFieldsCount = 0;
                    $(rowElement).find('input, select').each(function() {
                        const name = $(this).attr('name');
                        if (name && name.includes(`ValeursReference[${i}]`)) {
                            actualFieldsCount++;
                        }
                    });
                    
                    console.log(`[DEBUG] New row created with ${actualFieldsCount} fields (expected: ${expectedFields.length})`);
                    
                    // Append the DOM element directly
                    document.getElementById('referencesTableBody').appendChild(rowElement);
                    console.log(`[DEBUG] Row appended to table body`);
                    
                    // Update referenceIndex BEFORE reindexing to avoid conflicts
                    referenceIndex++;
                    console.log(`[DEBUG] Updated referenceIndex to: ${referenceIndex}`);
                    
                    // Reindex all rows to ensure proper sequential indexing
                    console.log(`[DEBUG] Starting reindexing process...`);
                    reindexRowsValeurReference();
                    
                    // Initialize Select2 on the new selects AFTER reindexing
                    console.log(`[DEBUG] Initializing Select2 on new elements...`);
                    $('#referencesTableBody tr:last-child select').each(function() {
                        const $select = $(this);
                        const name = $select.attr('name');
                        
                        try {
                            // Only initialize if not already initialized
                            if (!$select.hasClass('select2-hidden-accessible')) {
                                $select.select2({
                                    width: '100%',
                                    placeholder: '---'
                                });
                                console.log(`[DEBUG] Select2 initialized for: ${name}`);
                            } else {
                                console.log(`[DEBUG] Select2 already initialized for: ${name}`);
                            }
                        } catch (ex) {
                            console.error(`[DEBUG] Failed to initialize Select2 for ${name}:`, ex.message);
                        }
                    });
                    
                    console.log(`[DEBUG] Successfully added new reference row with final index: ${referenceIndex - 1}`);
                    
                } catch (error) {
                    console.error('[DEBUG] Error adding new reference row:', error.message);
                    alert('ERREUR lors de l\'ajout de la nouvelle ligne: ' + error.message);
                    
                    // Rollback referenceIndex if it was incremented
                    if (referenceIndex > $('#referencesTableBody tr').length) {
                        referenceIndex = $('#referencesTableBody tr').length;
                        console.log(`[DEBUG] Rolled back referenceIndex to: ${referenceIndex}`);
                    }
                }
            });

        });

