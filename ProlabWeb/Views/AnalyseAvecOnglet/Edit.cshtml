    <script>
        function initializeTabs() {
            console.log('=== Initializing Tab System ===');
            
            // Clear any existing handlers to avoid conflicts
            $('.tab-button').off('click');
            
            // Setup fresh click handlers
            $('.tab-button').on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                var clickedTabId = $(this).attr('id');
                console.log('Tab clicked:', clickedTabId);
                
                // Calculate target content ID
                var targetContentId = clickedTabId.replace('tab-', 'content-');
                console.log('Target content:', targetContentId);
                
                // Update all tab buttons to inactive state
                $('.tab-button').removeClass('active border-primary text-primary');
                $('.tab-button').addClass('border-transparent text-gray-500');
                
                // Set clicked tab to active state
                $(this).removeClass('border-transparent text-gray-500');
                $(this).addClass('active border-primary text-primary');
                
                // Hide all tab content
                $('.tab-content').addClass('hidden');
                
                // Show target content
                $('#' + targetContentId).removeClass('hidden');
                
                console.log('Tab switch completed:', targetContentId);
            });
            
            // Set initial state - first tab active
            $('#tab-general').removeClass('border-transparent text-gray-500');
            $('#tab-general').addClass('active border-primary text-primary');
            $('#content-general').removeClass('hidden');
            
            // Verify setup
            var tabButtons = $('.tab-button').length;
            var tabContents = $('.tab-content').length;
            console.log('Setup complete:', tabButtons, 'buttons,', tabContents, 'content areas');
        }
        
