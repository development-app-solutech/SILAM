                                    // Initialize Select2 on the new field
                                    $newSelect.select2({ width: '100%' });
                                    
                                    totalCleanedFields++;
                                }
                            }
                        }
                    });
                    
                    // 4. Fix any malformed field names
                    let malformedFieldsFound = false;
                    $('#referencesTableBody input, #referencesTableBody select').each(function() {
                        const $element = $(this);
                        const name = $element.attr('name');
                        
                        if (name && name.includes('ValeursReference[') && !name.match(/ValeursReference\[\d+\]\./)) {
                            malformedFieldsFound = true;
                        }
                    });
                    
                    if (malformedFieldsFound) {
                        reindexRowsValeurReference();
                        totalCleanedFields++;
                    }
                    
                    // 5. Final validation check
                    const serializedData = $('#analyseForm').serialize();
                    let hasSerializationIssues = false;
                    let detectedIssues = [];
                    
                    // Check for empty indexes in serialized data
                    if (serializedData.includes('ValeursReference%5B%5D') || serializedData.includes('ValeursReference[]')) {
                        detectedIssues.push('Empty ValeursReference indexes found');
                        hasSerializationIssues = true;
                    }
                    
                    // CRITICAL: Check for missing required unit code fields AND fix null values
                    const rowCount = $('#referencesTableBody tr').length;
                    for (let i = 0; i < rowCount; i++) {
                        // Check actual field values first and fix null values
                        const $codeunitagedebutSelect = $(`select[name="ValeursReference[${i}].Codeunitagedebut"]`);
                        const $codeunitagefinSelect = $(`select[name="ValeursReference[${i}].Codeunitagefin"]`);
                        
                        // Fix null or empty Codeunitagedebut values
                        if ($codeunitagedebutSelect.length > 0) {
                            const currentDebutValue = $codeunitagedebutSelect.val();
                            if (!currentDebutValue || currentDebutValue === '' || currentDebutValue === 'null' || currentDebutValue === null) {
                                // Try to set a valid default value
                                const firstValidOption = $codeunitagedebutSelect.find('option').filter(function() {
                                    const val = $(this).val();
                                    return val && val !== '' && val !== 'null' && val !== null;
                                }).first();
                                
                                if (firstValidOption.length > 0) {
                                    const newValue = firstValidOption.val();
                                    $codeunitagedebutSelect.val(newValue);
                                    $codeunitagedebutSelect.trigger('change');
                                    totalCleanedFields++;
                                } else {
                                    detectedIssues.push(`Missing Codeunitagedebut for ValeursReference[${i}]`);
                                    hasSerializationIssues = true;
                                }
                            }
                        } else {
                            detectedIssues.push(`Missing Codeunitagedebut for ValeursReference[${i}]`);
                            hasSerializationIssues = true;
                        }
                        
                        // Fix null or empty Codeunitagefin values
                        if ($codeunitagefinSelect.length > 0) {
                            const currentFinValue = $codeunitagefinSelect.val();
                            if (!currentFinValue || currentFinValue === '' || currentFinValue === 'null' || currentFinValue === null) {
                                // Try to set a valid default value
                                const firstValidOption = $codeunitagefinSelect.find('option').filter(function() {
                                    const val = $(this).val();
                                    return val && val !== '' && val !== 'null' && val !== null;
                                }).first();
                                
                                if (firstValidOption.length > 0) {
                                    const newValue = firstValidOption.val();
                                    $codeunitagefinSelect.val(newValue);
                                    $codeunitagefinSelect.trigger('change');
                                    totalCleanedFields++;
                                } else {
                                    detectedIssues.push(`Missing Codeunitagefin for ValeursReference[${i}]`);
                                    hasSerializationIssues = true;
                                }
                            }
                        } else {
                            detectedIssues.push(`Missing Codeunitagefin for ValeursReference[${i}]`);
                            hasSerializationIssues = true;
                        }
                    }
                    
                    // Check for malformed field patterns
                    const problematicPatterns = [
                        { pattern: /ValeursReference%5B%5D/g, name: 'Empty indexes (ValeursReference[])' },
                        { pattern: /%27/g, name: 'Single quotes encoded' },
                        { pattern: /%22/g, name: 'Double quotes encoded' },
                        { pattern: /%3C/g, name: 'Less-than symbols encoded' },
                        { pattern: /%3E/g, name: 'Greater-than symbols encoded' }
                    ];
                    
                    problematicPatterns.forEach((item, index) => {
                        if (item.pattern.test(serializedData)) {
                            detectedIssues.push(item.name);
                            hasSerializationIssues = true;
                        }
                    });
                    
                if (hasSerializationIssues) {
                        const detailedError = `Serialization validation failed. Issues found: ${JSON.stringify(detectedIssues)}`;
                        return { success: false, totalCleaned: totalCleanedFields, error: detailedError };
                    }
                    
                    return { success: true, totalCleaned: totalCleanedFields };
                    
                } catch (error) {
                    return { success: false, totalCleaned: totalCleanedFields, error: error.message };
                }
            };

            // REDESIGNED: Create safe select options function that handles problematic values
            function createSafeSelectOptions(options, targetSelectElement) {
                try {
                    // Validate inputs
                    if (!Array.isArray(options)) {
                        options = []; // Fallback to empty array
                    }
                    
                    if (!targetSelectElement || !targetSelectElement.tagName || targetSelectElement.tagName.toLowerCase() !== 'select') {
                        return;
                    }
                    
                    // Clear existing options
                    targetSelectElement.innerHTML = '';
                    
                    // Always add a default empty option first
                    const defaultOption = document.createElement('option');
                    defaultOption.value = '';
                    defaultOption.textContent = '---';
                    targetSelectElement.appendChild(defaultOption);
                    
                    // Add provided options
                    for (let i = 0; i < options.length; i++) {
                        try {
                            const optionData = options[i];
                            if (!optionData || (typeof optionData !== 'object' && typeof optionData !== 'string')) {
                                continue;
                            }
                            
                            const option = document.createElement('option');
                            
                            // Handle both object format {value: 'x', text: 'y'} and string format
                            let rawValue, displayText;
                            if (typeof optionData === 'string') {
                                rawValue = optionData;
                                displayText = optionData;
                            } else {
                                rawValue = optionData.value || optionData.Value || '';
                                displayText = optionData.text || optionData.Text || rawValue;
                            }
                            
                            // Sanitize the value to remove single quotes and other problematic characters
                            let cleanValue = String(rawValue);
                            if (cleanValue) {
                                cleanValue = cleanValue.replace(/'/g, ''); // Remove single quotes
                                cleanValue = cleanValue.replace(/"/g, ''); // Remove double quotes
                                cleanValue = cleanValue.replace(/[\\<>&;]/g, ''); // Remove other problematic chars
                                cleanValue = cleanValue.trim(); // Remove extra whitespace
                            }
                            
                            // Sanitize display text as well (but less aggressively)
                            let cleanText = String(displayText);
                            if (cleanText) {
                                cleanText = cleanText.trim();
                            }
                            
                            option.value = cleanValue;
                            option.textContent = cleanText || cleanValue;
                            targetSelectElement.appendChild(option);
                            
                        } catch (optionError) {
                            // Skip problematic options silently
                        }
                    }
                    
                } catch (error) {
                    // Fallback: create at least an empty option
                    try {
                        targetSelectElement.innerHTML = '<option value="">---</option>';
                    } catch (fallbackError) {
                        // Ignore fallback errors
                    }
                }
            }

