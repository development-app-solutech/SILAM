            function reindexRowsValeurReference() {
                console.log('[DEBUG] Reindexing ValeursReference rows');
                let hasChanges = false;
                
                $('#referencesTableBody tr').each(function (rowIndex, row) {
                    $(row).find('input, select').each(function () {
                        const $element = $(this);
                        const name = $element.attr('name');
                        const id = $element.attr('id');
                        
                        if (name && name.includes('ValeursReference[')) {
                            // Only reindex if the current index doesn't match the row index
                            const currentIndex = name.match(/ValeursReference\[(\d+)\]/);
                            if (currentIndex && parseInt(currentIndex[1]) !== rowIndex) {
                                const newName = name.replace(/ValeursReference\[\d+\]/, `ValeursReference[${rowIndex}]`);
                                $element.attr('name', newName);
                                console.log('[DEBUG] Updated name from', name, 'to', newName);
                                hasChanges = true;
                                
                                // Verify the new name is valid
                                if (!newName.match(/ValeursReference\[\d+\]\./)) {
                                    console.error('[DEBUG] WARNING: Generated invalid field name:', newName);
                                }
                            }
                        }
                        
                        if (id && id.includes('ValeursReference[')) {
                            const currentIndex = id.match(/ValeursReference\[(\d+)\]/);
                            if (currentIndex && parseInt(currentIndex[1]) !== rowIndex) {
                                const newId = id.replace(/ValeursReference\[\d+\]/, `ValeursReference[${rowIndex}]`);
                                $element.attr('id', newId);
                                console.log('[DEBUG] Updated id from', id, 'to', newId);
                                hasChanges = true;
                            }
                        }
                    });
                });

                if (!hasChanges) {
                    console.log('[DEBUG] No reindexing needed - all fields already properly indexed');
                }

                referenceIndex = $('#referencesTableBody tr').length;
                console.log('[DEBUG] Reference index set to:', referenceIndex);
            }

