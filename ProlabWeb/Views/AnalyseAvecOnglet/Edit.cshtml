    <script>
        $(function () {

            // Initialize referenceIndex based on existing rows
            let referenceIndex = $('#referencesTableBody tr').length;
            
            // Sanitize existing rows on page load - remove single quotes from unit codes
            $('#referencesTableBody select').each(function() {
                const $select = $(this);
                const name = $select.attr('name');
                const value = $select.val();
                
                // Check if this is a unit code field and has a single quote
                if (name && (name.includes('Codeunitagedebut') || name.includes('Codeunitagefin') || 
                            name.includes('Codeunitreference') || name.includes('Codeunitreferencesi')) && 
                    value && value.includes("'")) {
                    
                    const cleanedValue = value.replace(/'/g, '');
                    $select.val(cleanedValue);
                }
                
                // Ensure Select2 is properly initialized
                if (!$(this).hasClass('select2-hidden-accessible')) {
                    $(this).select2({
                        width: '100%'
                    });
                }
            });

            
            // COMPREHENSIVE FORM CLEANING FUNCTION (Global scope for reuse)
            window.performComprehensiveFormCleaning = function() {
                let totalCleanedFields = 0;
                
                try {
                    // 1. Clean all select fields (remove problematic characters)
                    $('#analyseForm select').each(function() {
                        const $select = $(this);
                        const name = $select.attr('name');
                        let value = $select.val();
                        
                        if (value && typeof value === 'string') {
                            let cleanedValue = value;
                            let wasChanged = false;
                            
                            // Remove single quotes
                            if (cleanedValue.includes("'")) {
                                cleanedValue = cleanedValue.replace(/'/g, '');
                                wasChanged = true;
                            }
                            
                            // Remove double quotes
                            if (cleanedValue.includes('"')) {
                                cleanedValue = cleanedValue.replace(/"/g, '');
                                wasChanged = true;
                            }
                            
                            // Remove other problematic characters
                            const problematicChars = /[\\<>&;]/g;
                            if (problematicChars.test(cleanedValue)) {
                                cleanedValue = cleanedValue.replace(problematicChars, '');
                                wasChanged = true;
                            }
                            
                            // Trim whitespace
                            cleanedValue = cleanedValue.trim();
                            
                            if (wasChanged) {
                                $select.val(cleanedValue);
                                totalCleanedFields++;
                            }
                        }
                    });
                    
                    // 2. Clean all input fields
                    $('#analyseForm input[type="text"], #analyseForm textarea').each(function() {
                        const $input = $(this);
                        const name = $input.attr('name');
                        let value = $input.val();
                        
                        if (value && typeof value === 'string') {
                            let cleanedValue = value;
                            let wasChanged = false;
                            
                            // For text fields, be more conservative - only remove really problematic chars
                            const reallyProblematicChars = /[\\<>&]/g;
                            if (reallyProblematicChars.test(cleanedValue)) {
                                cleanedValue = cleanedValue.replace(reallyProblematicChars, '');
                                wasChanged = true;
                            }
                            
                            if (wasChanged) {
                                $input.val(cleanedValue);
                                totalCleanedFields++;
                            }
                        }
                    });
                    
                    // 3. CRITICAL FIX: Ensure ALL required ValeursReference fields exist
                    $('#referencesTableBody tr').each(function(index) {
                        const $row = $(this);
                        
                        // Fix missing Idanalyse
                        let $idanalyseField = $row.find(`input[name="ValeursReference[${index}].Idanalyse"]`);
                        if ($idanalyseField.length === 0) {
                            // Create the missing Idanalyse field
                            const hiddenIdanalyse = $('<input type="hidden">');
                            hiddenIdanalyse.attr('name', `ValeursReference[${index}].Idanalyse`);
                            hiddenIdanalyse.val(currentAnalyseId);
                            $row.prepend(hiddenIdanalyse);
                            totalCleanedFields++;
                        } else if (!$idanalyseField.val()) {
                            $idanalyseField.val(currentAnalyseId);
                            totalCleanedFields++;
                        }
                        
                        // CRITICAL: Fix missing Codeunitagedebut fields
                        let $codeunitagedebutField = $row.find(`select[name="ValeursReference[${index}].Codeunitagedebut"]`);
                        if ($codeunitagedebutField.length === 0) {
                            // Try to find the age debut input and add the select after it
                            const $agedebutInput = $row.find(`input[name="ValeursReference[${index}].Agedebut"]`);
                            if ($agedebutInput.length > 0) {
                                const $selectContainer = $agedebutInput.closest('div');
                                if ($selectContainer.length > 0) {
                                    // Create the missing select element
                                    const $newSelect = $('<select>');
                                    $newSelect.addClass('kt-select w-100 js-example-basic-single');
                                    $newSelect.attr('name', `ValeursReference[${index}].Codeunitagedebut`);
                                    $newSelect.attr('id', `ValeursReference[${index}].Codeunitagedebut`);
                                    
                                    // Add default options
                                    if (typeof codeUniteOptions !== 'undefined' && codeUniteOptions.length > 0) {
                                        codeUniteOptions.forEach(function(option) {
                                            const $option = $('<option>');
                                            let cleanValue = (option.value || '').replace(/'/g, '').trim();
                                            $option.val(cleanValue);
                                            $option.text(option.text || cleanValue);
                                            $newSelect.append($option);
                                        });
                                    }
                                    
                                    $selectContainer.append($newSelect);
                                    
                                    // Initialize Select2 on the new field
                                    $newSelect.select2({ width: '100%' });
                                    
                                    totalCleanedFields++;
                                }
                            }
                        }
                        
                        // CRITICAL: Fix missing Codeunitagefin fields
                        let $codeunitagefinField = $row.find(`select[name="ValeursReference[${index}].Codeunitagefin"]`);
                        if ($codeunitagefinField.length === 0) {
                            // Try to find the age fin input and add the select after it
                            const $agefinInput = $row.find(`input[name="ValeursReference[${index}].Agefin"]`);
                            if ($agefinInput.length > 0) {
                                const $selectContainer = $agefinInput.closest('div');
                                if ($selectContainer.length > 0) {
                                    // Create the missing select element
                                    const $newSelect = $('<select>');
                                    $newSelect.addClass('kt-select w-100 js-example-basic-single');
                                    $newSelect.attr('name', `ValeursReference[${index}].Codeunitagefin`);
                                    $newSelect.attr('id', `ValeursReference[${index}].Codeunitagefin`);
                                    
                                    // Add default options
                                    if (typeof codeUniteOptions !== 'undefined' && codeUniteOptions.length > 0) {
                                        codeUniteOptions.forEach(function(option) {
                                            const $option = $('<option>');
                                            let cleanValue = (option.value || '').replace(/'/g, '').trim();
                                            $option.val(cleanValue);
