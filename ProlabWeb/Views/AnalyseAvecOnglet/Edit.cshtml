                console.log(`[DEBUG] Invalid fields: ${invalidFields.length}`);
                
                if (invalidFields.length > 0) {
                    console.error('[DEBUG] Invalid field names:', invalidFields);
                    alert(`ERREUR: ${invalidFields.length} champs invalides détectés:\n${invalidFields.join('\n')}`);
                } else {
                    // Additional validation: check for required Idanalyse fields
                    let missingIdanalyse = [];
                    $('#referencesTableBody input[name*=".Idanalyse"]').each(function() {
                        if (!$(this).val()) {
                            missingIdanalyse.push($(this).attr('name'));
                        }
                    });
                    
                    if (missingIdanalyse.length > 0) {
                        console.error('[DEBUG] Missing Idanalyse values:', missingIdanalyse);
                        alert(`ERREUR: ${missingIdanalyse.length} champs Idanalyse manquants`);
                    } else {
                        console.log('[DEBUG] All fields appear valid, submitting form...');
                        $('#analyseForm').off('submit').submit();
                    }
                }
            });
            
            // Force submit button - bypasses all validation
            $('#forceSubmit').on('click', function() {
                console.log('[DEBUG] Force submit clicked - bypassing all validation');
                
                // COMPREHENSIVE SERIALIZATION FIX: Clean all form data for safe submission
                console.log('[DEBUG] Force Submit: Comprehensive form data cleaning...');
                
                const cleaningResult = window.performComprehensiveFormCleaning();
                
                if (!cleaningResult.success) {
                    console.error('[DEBUG] Force submit aborted due to serialization issues:', cleaningResult.error);
                    alert('ERREUR CRITIQUE: Problèmes de sérialisation détectés. Impossible de soumettre le formulaire en toute sécurité.\n\nErreur: ' + cleaningResult.error);
                    return;
                }
                
                console.log(`[DEBUG] Force Submit: Successfully cleaned ${cleaningResult.totalCleaned} fields`);
                console.log('[DEBUG] Form data is now safe for submission.');
                
                const form = $('#analyseForm')[0];
                console.log('[DEBUG] Form element:', form);
                console.log('[DEBUG] Form action attribute:', form.getAttribute('action'));
                console.log('[DEBUG] Form action property:', form.action);
                console.log('[DEBUG] Form method:', form.method);
                console.log('[DEBUG] Current page URL:', window.location.href);
                console.log('[DEBUG] Base URL:', window.location.origin);
                
                // Disable HTML5 validation temporarily
                form.setAttribute('novalidate', 'novalidate');
                
                // Log form data before submission
                const formData = new FormData(form);
                console.log('[DEBUG] Form data entries:');
                for (let [key, value] of formData.entries()) {
                    if (key.includes('ValeursReference')) {
                        console.log(`[DEBUG] ${key} = ${value}`);
                    }
                }
                
                console.log('[DEBUG] Serialized form data:', $(form).serialize());
                
                // Check for problematic field patterns
                let hasEmptyIndexes = false;
                let hasMissingIdanalyse = false;
                
                for (let [key, value] of formData.entries()) {
                    if (key.includes('ValeursReference')) {
                        // Check for empty indexes like ValeursReference[].Property
                        if (key.match(/ValeursReference\[\]\./)) {
                            hasEmptyIndexes = true;
                            console.warn('[DEBUG] PROBLEM: Empty index found:', key);
                        }
                        
                        // Check for missing Idanalyse values
                        if (key.includes('.Idanalyse') && (!value || value === '')) {
                            hasMissingIdanalyse = true;
                            console.warn('[DEBUG] PROBLEM: Missing Idanalyse value for:', key);
                        }
                    }
                }
                
                if (hasEmptyIndexes) {
                    console.error('[DEBUG] CRITICAL: Found empty indexes in ValeursReference fields');
                }
                if (hasMissingIdanalyse) {
                    console.error('[DEBUG] CRITICAL: Found missing Idanalyse values');
                }
                
                // Remove any jQuery validation
                $('#analyseForm').off('submit');
                
                // Submit directly
                form.submit();
            });
        });


    </script>

}
