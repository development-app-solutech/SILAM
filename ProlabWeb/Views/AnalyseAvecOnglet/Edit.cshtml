                const $rows = $('#referencesTableBody tr');
                if ($rows.length === 0) return;

                // Supprime la dernière ligne
                $rows.last().remove();

                // Réindexe tous les champs
                reindexRowsValeurReference();
            });

            document.getElementById('addReference').addEventListener('click', function () {
                console.log(`[DEBUG] Adding new reference row with current referenceIndex: ${referenceIndex}`);
                
                // Validate required variables are available
                if (typeof sexeOptions === 'undefined' || !Array.isArray(sexeOptions)) {
                    console.error('[DEBUG] sexeOptions is not defined or not an array');
                    alert('ERREUR: Options de sexe non disponibles. Veuillez rafraîchir la page.');
                    return;
                }
                
                if (typeof codeUniteOptions === 'undefined' || !Array.isArray(codeUniteOptions)) {
