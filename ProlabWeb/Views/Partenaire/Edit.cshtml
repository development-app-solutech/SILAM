@model ProlabWeb.Db.Partenaire

@{
    ViewData["Title"] = "Modifier un partenaire";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Modifier un partenaire</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <form asp-action="Edit" method="post" class="flex flex-col gap-5">
        @Html.AntiForgeryToken()
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
        {
            <div class="alert alert-danger">
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }
        <div asp-validation-summary="ModelOnly" class="text-red-500"></div>

        <!-- Champ Partenaireid masqué - ne doit pas être modifié -->
        <input type="hidden" asp-for="Partenaireid" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="flex flex-col gap-5">
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Nom"></label>
                    <input class="kt-input" asp-for="Nom" placeholder="Nom du partenaire" type="text">
                    <span asp-validation-for="Nom" class="text-red-500"></span>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Description"></label>
                    <textarea class="kt-input" asp-for="Description" placeholder="Description du partenaire"
                        rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-red-500"></span>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Isactive"></label>
                    <div class="flex items-center gap-3">
                        <input type="checkbox" asp-for="Isactive" class="form-check-input" />
                        <span class="text-sm text-gray-600">Partenaire actif</span>
                    </div>
                    <span asp-validation-for="Isactive" class="text-red-500"></span>
                </div>
            </div>
            <div class="flex flex-col gap-5">
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Adresse"></label>
                    <textarea class="kt-input" asp-for="Adresse" placeholder="Adresse complète" rows="3"></textarea>
                    <span asp-validation-for="Adresse" class="text-red-500"></span>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Tel"></label>
                    <input class="kt-input" asp-for="Tel" placeholder="Numéro de téléphone" type="tel">
                    <span asp-validation-for="Tel" class="text-red-500"></span>
                </div>
            </div>
        </div>
        <div class="inline-flex justify-start grow">
            <button type="submit" class="kt-btn kt-btn-primary">
                <span class="material-symbols-outlined">
                    save
                </span> Enregistrer
            </button>
        </div>
    </form>
</div>
