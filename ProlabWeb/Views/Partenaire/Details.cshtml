@model ProlabWeb.Db.Partenaire

@{
    ViewData["Title"] = "Détails partenaire";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Détails partenaire</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-5">
            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Informations générales</h3>
                <div class="space-y-2">
                    <div><span class="font-semibold">Nom :</span> @Model.Nom</div>
                    <div><span class="font-semibold">Description :</span> @Model.Description</div>
                    <div>
                        <span class="font-semibold">Statut :</span>
                        @if (Model.Isactive)
                        {
                            <span class="kt-badge kt-badge-success kt-badge-outline rounded-[30px]">
                                <span class="kt-badge-dot size-1.5"></span>
                                Actif
                            </span>
                        }
                        else
                        {
                            <span class="kt-badge kt-badge-destructive kt-badge-outline rounded-[30px]">
                                <span class="kt-badge-dot size-1.5"></span>
                                Inactif
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="flex flex-col gap-5">
            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Contact</h3>
                <div class="space-y-2">
                    <div><span class="font-semibold">Adresse :</span> @Model.Adresse</div>
                    <div><span class="font-semibold">Téléphone :</span> @Model.Tel</div>
                </div>
            </div>
        </div>
    </div>
    <div class="flex justify-end gap-5 mt-5">
        <a asp-action="Index" class="kt-btn kt-btn-light">Retour à la liste</a>
        <a asp-action="Edit" asp-route-id="@Model?.Partenaireid" class="kt-btn kt-btn-primary">Modifier</a>
    </div>
</div>
