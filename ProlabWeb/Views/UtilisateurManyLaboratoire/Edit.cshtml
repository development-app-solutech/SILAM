@model ProlabWeb.ViewModels.UtilisateurManyLaboratoireEditVM

@{
    ViewData["Title"] = "Modifier un utilisateur laboratoire";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5">
    <div>
        <h1 class="font-bold">Modification d'un utilisateur laboratoire</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2">
    <span class="border-t border-border border-primary w-full"></span>
</div>

<div class="min-w-full mb-5">
    <form asp-action="Edit" class="flex flex-col gap-5" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-red-500"></div>
        <div class="grid grid-cols-2 gap-10">
            <div class="flex flex-col gap-5">
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Utilisateurid"></label>
                    <select class="kt-select w-100 js-example-basic-single" asp-for="Utilisateurid" asp-items="ViewBag.Utilisateurid" required>
                        <option value="">-- Sélectionner un utilisateur --</option>
                    </select>
                    <span asp-validation-for="Utilisateurid" class="text-red-500"></span>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Idslaboratoire"></label>
                    <select class="kt-select w-100 js-example-basic-multiple" asp-for="Idslaboratoire" asp-items="ViewBag.Idlaboratoire" required multiple>
                        <option value="">-- Sélectionner un laboratoire --</option>
                    </select>
                    <span asp-validation-for="Idslaboratoire" class="text-red-500"></span>
                </div>
            </div>
        </div>
        <div class="inline-flex justify-start grow">
            <button type="submit" class="kt-btn kt-btn-primary">
                <span class="material-symbols-outlined">
                    save
                </span> Enregistrer
            </button>
        </div>
    </form>
</div>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function() {

            $('.js-example-basic-single').select2({
                // theme: "classic",
                width: '100%'
            });

            $('.js-example-basic-multiple').select2({
                // theme: "classic",
                width: '100%'
            });

        });
    </script>
}
