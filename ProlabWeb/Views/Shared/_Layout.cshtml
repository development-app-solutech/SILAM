    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.30.1/moment.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.9.179/pdf.min.js"></script>
    
    <!-- Enhanced Dropdown Menu Script - Global Application -->
    <script src="~/js/enhanced-dropdown-menu.js"></script>
    <script>
        function updateThemeIcon() {
            const icon = document.getElementById('theme-icon');
            if (document.documentElement.classList.contains('dark')) {
                icon.textContent = 'light_mode';
            } else {
                icon.textContent = 'dark_mode';
            }
        }
        document.addEventListener('DOMContentLoaded', function () {
            const btn = document.getElementById('theme-toggle');
            if (btn) {
                btn.addEventListener('click', function () {
                    document.documentElement.classList.toggle('dark');
                    if (document.documentElement.classList.contains('dark')) {
                        localStorage.setItem('kt-theme', 'dark');
                    } else {
                        localStorage.setItem('kt-theme', 'light');
                    }
                    updateThemeIcon();
                });
                updateThemeIcon();
            }

            // Mobile menu toggle functionality
            const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
            const sidebar = document.getElementById('sidebar');
            const mobileOverlay = document.getElementById('mobile-overlay');

            function toggleMobileMenu() {
                console.log('Toggle mobile menu called');
                const isOpen = sidebar.classList.contains('open');
                console.log('Menu is currently open:', isOpen);
                
                if (isOpen) {
                    // Close menu
                    sidebar.classList.remove('open');
                    mobileOverlay.classList.remove('show');
                } else {
                    // Open menu
                    sidebar.classList.add('open');
                    mobileOverlay.classList.add('show');
                }
            }

            // Toggle menu when hamburger button is clicked
            if (mobileMenuToggle) {
                mobileMenuToggle.addEventListener('click', toggleMobileMenu);
            }

            // Close menu when overlay is clicked
            if (mobileOverlay) {
                mobileOverlay.addEventListener('click', toggleMobileMenu);
            }

            // Close menu when clicking on menu links (on mobile)
            const menuLinks = sidebar.querySelectorAll('a[href]');
            menuLinks.forEach(function(link) {
                link.addEventListener('click', function() {
                    // Only close on mobile (screen width < 1024px)
                    if (window.innerWidth < 1024) {
                        setTimeout(toggleMobileMenu, 100); // Small delay for better UX
                    }
                });
            });

            // Handle window resize to ensure proper state
            window.addEventListener('resize', function() {
                if (window.innerWidth >= 1024) {
                    // Desktop view - ensure menu is closed
                    sidebar.classList.remove('open');
                    mobileOverlay.classList.remove('show');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
