@model ProlabWeb.Db.Typeassurance

@{
    ViewData["Title"] = "Créer un type d'assurance";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Créer un type d'assurance</h1>
            </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <form asp-action="Create" method="post" class="flex flex-col gap-5">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-red-500"></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="flex flex-col gap-5">
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Codetypeassurance"></label>
                    <input class="kt-input" asp-for="Codetypeassurance" placeholder="Code du type d'assurance" type="text">
                    <span asp-validation-for="Codetypeassurance" class="text-red-500"></span>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Nom"></label>
                    <input class="kt-input" asp-for="Nom" placeholder="Nom du type d'assurance" type="text">
                    <span asp-validation-for="Nom" class="text-red-500"></span>
                </div>
            </div>
        </div>
        <div class="flex justify-end mt-6 space-x-3">
            <a asp-action="Index" class="kt-btn kt-btn-outline mr-4">Annuler</a>
            <button class="kt-btn kt-btn-primary" type="submit">Créer</button>
        </div>
    </form>
</div>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
