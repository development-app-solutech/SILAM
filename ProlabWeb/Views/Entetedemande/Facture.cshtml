@{
    Layout = null;
}

<div style="padding: 10px; background-color: #f8f9fa; border-bottom: 1px solid #dee2e6;">
    <a href="@Url.Action("Index", "Entetedemande")" style="display: inline-flex; align-items: center; padding: 8px 16px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px; font-size: 14px; font-weight: 500;">
        <svg style="width: 16px; height: 16px; margin-right: 8px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Retour à la liste
    </a>
</div>

@if (ViewData["ReportPdfBase64"] != null)
{
    <iframe width="100%" height="800" src="data:application/pdf;base64,@ViewData["ReportPdfBase64"]"></iframe>
}