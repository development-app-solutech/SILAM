@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function() {

            var defaultImage = '/img/photo_patient_default.png';
            var previewImage = document.querySelector('#imgImage');
            var fileImage = document.querySelector('[name="Patient.File"]');
            var filenameImage = document.querySelector('[name="Patient.Filename"]');
            var choisirImage = document.querySelector('#btnSelectImage');
            var annulerImage = document.querySelector('#btnCancelImage');

            var patient = document.querySelector('[name="Patientid"]');
            var estassure =  document.querySelector('[name="EstAssure"]');
            var prescripteur = document.querySelector('[name="Prescripteurid"]');

            var divPatient = document.querySelector('#divPatient');
            var fieldsetAssurance = document.querySelector('#fieldsetAssurance');
            var fieldsetPrescripteur = document.querySelector('#fieldsetPrescripteur');

            function setDefaultImage() {
                $(previewImage).attr('src', defaultImage);
                $(fileImage).val('');
                $(filenameImage).val('');
            }

            function resetPatient() {
                let selectionne = $(patient).val().trim() !== '';
                setDefaultImage();
                $(divPatient).find('input').val('');
                $(divPatient).find('select').not('[name="Patientid"]').val(null).trigger('change');
                $(divPatient).find('textarea[name="Patient.Renseignementclinique"]').summernote('code', '');
            }
            function togglePatient() {
                let selectionne = $(patient).val().trim() !== '';
                $(divPatient).find('input').prop('disabled', selectionne);
                $(divPatient).find('button').prop('disabled', selectionne);
                $(divPatient).find('select').not('[name="Patientid"]').prop('disabled', selectionne);
                $(divPatient).find('textarea[name="Patient.Renseignementclinique"]').summernote(selectionne ? 'disable' : 'enable');
            }

            function resetAssurance() {
                let coche = $(estassure).is(':checked');
                $(fieldsetAssurance).find('select').val(null).trigger('change');
            }
            function toggleAssurance() {
                let coche = $(estassure).is(':checked');
                $(fieldsetAssurance).find('select').prop('disabled', !coche);
            }

            function resetPrescripteur() {
                let selectionne = $(prescripteur).val().trim() !== '';
                $(fieldsetPrescripteur).find('input').val('');
                $(fieldsetPrescripteur).find('textarea[name="Prescripteur.Description"]').summernote('code', '');
            }
            function togglePrescripteur() {
                let selectionne = $(prescripteur).val().trim() !== '';
                $(fieldsetPrescripteur).find('input').prop('disabled', selectionne);
                $(fieldsetPrescripteur).find('textarea[name="Prescripteur.Description"]').summernote(selectionne ? 'disable' : 'enable');
            }

            function extractPriceFromOptionText(optionText) {
                if (!optionText) return 0;

                // Format attendu: "Nom (12 000)"
                const match = optionText.match(/\(([^)]+)\)\s*$/);
                if (!match) return 0;

                const digitsOnly = match[1].replace(/[^\d]/g, '');
                const parsed = parseInt(digitsOnly, 10);
                return Number.isNaN(parsed) ? 0 : parsed;
            }

            function sumSelectedOptions(selectName) {
                let total = 0;
                $(`[name="${selectName}"] option:selected`).each(function () {
                    const optionValue = $(this).val();
                    if (!optionValue) return;
                    total += extractPriceFromOptionText($(this).text());
                });
                return total;
            }

            function updateAnalyseTotal() {
                const totalCategories = sumSelectedOptions('IdsCategorie');
                const totalAnalyses = sumSelectedOptions('IdsAnalyse');
                const total = totalCategories + totalAnalyses;

                $('#analyseTotalDisplay').text(`Total: ${total.toLocaleString('fr-FR')} FCFA`);
            }

            togglePatient();
            toggleAssurance();
            togglePrescripteur();

            $(patient).on('change', function() {

                let id = $(this).val();

                $.ajax({
                    url: `/Patient/GetPatient?id=${id}`,
                    type: 'GET',
                    dataType: 'json',
                    beforeSend: function() {
                        console.log('before');
                        resetPatient();
                    },
                    success: function(response) {
                        if (response.success) {
                            let data = JSON.parse(response.data);
                            console.log('data', data);

                            $('[name="Patient.Nom"]').val(data.Nom);
                            $('[name="Patient.Prenom"]').val(data.Prenom);
                            $('[name="Patient.Nomusage"]').val(data.Nomusage);
                            $('[name="Patient.Codesexe"]').val(data.Codesexe).trigger('change');
                            $('[name="Patient.Codetypepeau"]').val(data.Codetypepeau).trigger('change');
                            $('[name="Patient.Datenaissance"]').val(data.Datenaissance);
                            $('[name="Patient.Lieunaissance"]').val(data.Lieunaissance);
                            $('[name="Patient.Codetypedocumentidentite"]').val(data.Codetypedocumentidentite).trigger('change');
                            $('[name="Patient.Numerodocumentidentite"]').val(data.Numerodocumentidentite);
                            $('[name="Patient.Adresse"]').val(data.Adresse);
                            $('[name="Patient.Tel"]').val(data.Tel);
                            $('[name="Patient.Email"]').val(data.Email);
                            $('[name="Patient.Ville"]').val(data.Ville);
                            $('[name="Patient.Quartier"]').val(data.Quartier);
                            $('[name="Patient.Renseignementclinique"]').summernote('code', data.Renseignementclinique);
                            $(previewImage).attr('src', data.PhotoBase64);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Request failed:', status, error);
                    },
                    complete: function(xhr, status) {
                        togglePatient();
                    }
                });
            });

            $(estassure).on('change', function() {
                resetAssurance();
                toggleAssurance();
            });

            $('[name="Codeassurance"]').on('change', function() {

                let id = $(this).val();

                $.ajax({
                    url: `/Policeassurance/GetPoliceassuranceByAssurance?id=${id}`,
                    type: 'GET',
                    dataType: 'json',
                    beforeSend: function() {
                        console.log('before');

                        $('[name="Policeassuranceid"]').empty();
                        $('[name="Policeassuranceid"]').append('<option value="">---</option>');
                    },
                    success: function(response) {
                        if (response.success) {
                            let data = JSON.parse(response.data);
                            console.log('data', data);

                            $.each(data, function(index, value) {
                                $('[name="Policeassuranceid"]').append(`<option value="${value.Value}">${value.Text}</option>`);
                            });
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Request failed:', status, error);
                    },
                    complete: function(xhr, status) {
                    }
                });
            });

            $(prescripteur).on('change', function() {

                let id = $(this).val();

                $.ajax({
                    url: `/Prescripteur/GetPrescripteur?id=${id}`,
                    type: 'GET',
                    dataType: 'json',
                    beforeSend: function() {
                        console.log('before');
                        resetPrescripteur();
                    },
                    success: function(response) {
                        if (response.success) {
                            let data = JSON.parse(response.data);
                            console.log('data', data);

                            $('[name="Prescripteur.Nom"]').val(data.Nom);
                            $('[name="Prescripteur.Description"]').summernote('code', data.Description);
                            $('[name="Prescripteur.Adresse"]').val(data.Adresse);
                            $('[name="Prescripteur.Tel"]').val(data.Tel);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Request failed:', status, error);
                    },
                    complete: function(xhr, status) {
                        togglePrescripteur();
                    }
                });
            });

            $(choisirImage).on('click', function(e) {
                e.preventDefault();
                $(fileImage).click();
            });

            $(fileImage).on('change', function (event) {
                const file = event.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $(previewImage).attr('src', e.target.result); // Set image preview
                        $(filenameImage).val(file.name);
                    };
                    reader.readAsDataURL(file);
                }
            });

            $(previewImage).on('error', function () {
                setDefaultImage();
            });

            $(annulerImage).on('click', function (e) {
                e.preventDefault();
                setDefaultImage();
            });

            $('.js-example-basic-single').select2({
                // theme: "classic",
                width: '100%'
            });

            $('.js-example-basic-multiple').select2({
                // theme: "classic",
                width: '100%'
            });

            $('[name="IdsCategorie"], [name="IdsAnalyse"]').on('change', updateAnalyseTotal);
            updateAnalyseTotal();

            $('.summernote').summernote({
                placeholder: '',
                tabsize: 2,
                height: 120,
                toolbar: [
                ['style', ['style']],
                ['font', ['bold', 'underline', 'clear']],
                ['color', ['color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['table', ['table']],
                ['insert', ['link', 'picture', 'video']],
                ['view', ['fullscreen', 'codeview', 'help']]
                ]
            });

        });
