@model ProlabWeb.ViewModels.UtilisateurDetailsVM

@{
    ViewData["Title"] = "Détails utilisateur";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Détails utilisateur</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>

<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>

<div class="min-w-full mb-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-5">
            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Informations de base</h3>
                <div class="space-y-2">
                    <div><span class="font-semibold">Nom :</span> @Model.Nom</div>
                    <div><span class="font-semibold">Prénom :</span> @Model.Prenom</div>
                    <div><span class="font-semibold">Sexe :</span> @Model.Codesexe</div>
                    <div><span class="font-semibold">Date de naissance :</span> @Model.Datenaissance</div>
                    <div><span class="font-semibold">Nationalité :</span> @Model.Nationnalite</div>
                    <div><span class="font-semibold">Site :</span> @Model.Codesite</div>
                    <div><span class="font-semibold">Matricule :</span> @Model.Matricule</div>
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-5">
            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Contact</h3>
                <div class="space-y-2">
                    <div><span class="font-semibold">Téléphone 1 :</span> @Model.Tel1</div>
                    <div><span class="font-semibold">Téléphone 2 :</span> @Model.Tel2</div>
                    <div><span class="font-semibold">Mobile 1 :</span> @Model.Mob1</div>
                    <div><span class="font-semibold">Mobile 2 :</span> @Model.Mob2</div>
                    <div><span class="font-semibold">Email :</span> @Model.Email</div>
                </div>
            </div>

            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Sécurité & Statut</h3>
                <div class="space-y-2">
                    <div><span class="font-semibold">Login :</span> @Model.Login</div>
                    <div>
                        <span class="font-semibold">Mot de passe :</span>
                        @if (!string.IsNullOrEmpty(Model.PasswordToShow))
                        {
                            <span class="text-red-600 font-bold">@Model.PasswordToShow</span>
                        }
                        else
                        {
                            <span>********</span>
                        }
                    </div>
                </div>

                <!-- Success/Error Messages -->
                @if (TempData["Success"] != null)
                {
                    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                        @TempData["Error"]
                    </div>
                }

                <form asp-action="ResetPassword" method="post" class="mt-4" onsubmit="return confirmReset()">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Utilisateurid" />
                    <button type="submit" class="kt-btn kt-btn-warning">
                        <i class="fas fa-key mr-2"></i>Reset Password
                    </button>
                </form>

                <script>
                    function confirmReset() {
                        return confirm('Êtes-vous sûr de vouloir réinitialiser le mot de passe de cet utilisateur ?');
                    }
                </script>
            </div>
        </div>
    </div>

    @* <div class="flex justify-end mt-6 space-x-3">
        <a asp-action="Edit" asp-route-id="@Model?.Utilisateurid" class="kt-btn kt-btn-outline mr-4">Modifier</a>
        <a asp-action="Index" class="kt-btn kt-btn-primary">Retour à la liste</a>
    </div> *@
</div>
