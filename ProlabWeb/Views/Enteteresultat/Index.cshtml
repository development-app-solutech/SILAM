@model IEnumerable<ProlabWeb.Db.Enteteresultat>

@{
    ViewData["Title"] = "Liste des résultats d'analyse";
}

<!-- Modern Header Section -->
<div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-6 mb-6 border border-blue-100">
    <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
            <div class="bg-blue-500 p-3 rounded-xl shadow-lg">
                <span class="material-symbols-outlined text-white text-2xl">
                    science
                </span>
            </div>
            <div>
                <h1 class="text-3xl font-bold text-gray-800 mb-2">Résultats d'Analyse</h1>
                <p class="text-gray-600 text-sm">Gestion et suivi des résultats de laboratoire</p>
            </div>
        </div>
        <div class="text-right">
            <div class="text-2xl font-bold text-blue-600" id="totalResultsCount">@Model.Count()</div>
            <div class="text-sm text-gray-500">Résultats totaux</div>
        </div>
    </div>
</div>

<!-- Enhanced Filter and Actions Section -->
<div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-6 overflow-hidden">
    <div class="p-6 border-b border-gray-100">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div class="flex flex-col sm:flex-row gap-4 flex-1">
                <!-- Enhanced Search -->
                <div class="relative flex-1 max-w-md">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-gray-400 text-xl">
                            search
                        </span>
                    </div>
                    <input 
                        class="block w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-gray-50 focus:bg-white transition-all duration-200" 
                        placeholder="Rechercher par numéro, patient, prescripteur..." 
                        type="text" 
                        data-kt-enteteresultat-table-filter="search">
                </div>
                
                <!-- Date Filter -->
                <div class="flex gap-2">
                    <input 
                        type="date" 
                        class="px-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200" 
                        id="dateFrom" 
                        placeholder="Date début">
                    <input 
                        type="date" 
                        class="px-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200" 
                        id="dateTo" 
                        placeholder="Date fin">
                </div>
                
                <!-- Status Filter -->
                <select class="px-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white transition-all duration-200" id="statusFilter">
                    <option value="">Tous les statuts</option>
                    <option value="validated">Validé</option>
                    <option value="pending">En attente</option>
                </select>
            </div>
            
            <!-- Actions -->
            <div class="flex items-center gap-3">
                <div class="flex items-center gap-2 text-sm text-gray-500">
                    <span id="selectedCount">0</span> sélectionné(s)
                </div>
                
                <!-- Bulk Actions -->
                <div class="hidden" id="bulkActions">
                    <button class="px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 transition-colors duration-200 flex items-center gap-2 text-sm">
                        <span class="material-symbols-outlined text-lg">print</span>
                        Imprimer sélection
                    </button>
                </div>
                
                @if (!User.IsInRole(EnumRoles.Caisse.ToString()))
                {
                    <a asp-action="Create" class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-lg transition-all duration-200 flex items-center gap-2 font-medium shadow-sm hover:shadow-md">
                        <span class="material-symbols-outlined text-lg">
                            add
                        </span> 
                        Nouveau résultat
                    </a>
                }
            </div>
        </div>
    </div>
    
    <!-- Quick Stats -->
    <div class="px-6 py-4 bg-gray-50 border-b border-gray-100">
        <div class="flex items-center justify-between text-sm">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                    <span class="text-gray-600">Validés: <span class="font-medium" id="validatedCount">@Model.Count(r => r.Statut == "valide")</span></span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                    <span class="text-gray-600">En attente: <span class="font-medium" id="pendingCount">@Model.Count(r => r.Statut != "valide")</span></span>
                </div>
            </div>
            <div class="text-gray-500">
                Dernière mise à jour: <span id="lastUpdate">@DateTime.Now.ToString("HH:mm")</span>
            </div>
        </div>
    </div>
</div>

<div class="min-w-full">
    <div class="grid gap-5" data-kt-datatable="true" data-kt-datatable-page-size="10">
        <!-- Modern Table/Card View -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <!-- Table Header -->
            <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <input class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" id="selectAllCheckbox" type="checkbox">
                        <span class="text-sm font-medium text-gray-700">Sélectionner tout</span>
                    </div>
                    <div class="flex items-center gap-2 text-sm text-gray-500">
                        <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24">visibility</span>
                        <span id="visibleCount">@Model.Count()</span> résultats affichés
                    </div>
                </div>
            </div>
            
            <div class="kt-scrollable-x-auto">
                <table id="enteteresultat-table" class="w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="w-12 px-6 py-4 text-left">
                                <span class="sr-only">Sélection</span>
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Date
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Numéro
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Patient
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Prescripteur
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Assurance
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Analyse
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Statut
                            </th>
                            <th class="w-16 px-6 py-4 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Actions
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-colors duration-150 group">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <input class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded row-checkbox" type="checkbox" value="@item.Enteteresultatid">
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex flex-col">
                                        <div class="text-sm font-medium text-gray-900">@item.Date.ToString("dd/MM/yyyy")</div>
                                        <div class="text-xs text-gray-500">@item.Date.ToString("HH:mm")</div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded-full inline-flex items-center">
                                        <span class="material-symbols-outlined text-sm mr-1" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24">tag</span>
                                        @item.Entetedemande.Numero
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-8 w-8">
                                            <div class="h-8 w-8 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                                                <span class="text-white text-sm font-medium">
                                                    @{
                                                        var nomInitial = item.Entetedemande.Patient.Nom?.Substring(0, 1).ToUpper() ?? "";
                                                        var prenomInitial = item.Entetedemande.Patient.Prenom?.Substring(0, 1).ToUpper() ?? "";
                                                    }
                                                    @nomInitial@prenomInitial
                                                </span>
                                            </div>
                                        </div>
                                        <div class="ml-3">
                                            <div class="text-sm font-medium text-gray-900">@item.Entetedemande.Patient.Nom @item.Entetedemande.Patient.Prenom</div>
                                            <div class="text-xs text-gray-500">Patient</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-900 font-medium">@item.Entetedemande.Prescripteur.Nom</div>
                                    <div class="text-xs text-gray-500">Prescripteur</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-900">
                                        @{
                                            var assuranceNom = item.Entetedemande.Policeassurance?.CodeassuranceNavigation?.Nom ?? "";
                                        }
                                        @assuranceNom
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="bg-purple-100 text-purple-800 text-xs font-medium px-3 py-1 rounded-full">
                                        @item.IdanalyseNavigation.Nom
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if (item.Statut == "valide")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                            <span class="material-symbols-outlined text-sm mr-1" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24">check_circle</span>
                                            Validé
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                            <span class="material-symbols-outlined text-sm mr-1" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24">pending</span>
                                            En attente
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <div class="relative inline-block text-left" data-kt-dropdown="true" data-kt-dropdown-placement="bottom-end" data-kt-dropdown-trigger="click">
                                        <button type="button" class="inline-flex items-center p-2 text-gray-400 hover:text-gray-600 rounded-full hover:bg-gray-100 transition-all duration-200 group-hover:bg-gray-200" data-kt-dropdown-toggle="true">
                                            <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24">more_vert</span>
                                        </button>
                                        <div class="absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-lg bg-white shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none hidden" data-kt-dropdown-menu="true" style="opacity: 0;">
                                            <div class="py-1">
                                                <a asp-action="Edit" 
                                                   asp-route-id="@item.Enteteresultatid" 
                                                   class="group flex items-center px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-900 transition-colors duration-200 edit-link"
                                                   data-kt-dropdown-dismiss="true"
                                                   data-loading-text="Chargement...">
                                                    <span class="material-symbols-outlined text-blue-500 mr-3 text-lg" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24">edit</span>
                                                    <span class="link-text">Modifier</span>
                                                    <div class="hidden animate-spin ml-2" data-spinner>
                                                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none">
                                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                                        </svg>
                                                    </div>
                                                </a>
                                                @if (item.Statut == "valide")
                                                {
                                                    <a href="#" 
                                                       data-id="@item.Enteteresultatid"
                                                       data-kt-enteteresultat-table-filter="print_row"
                                                       class="group flex items-center px-4 py-3 text-sm text-gray-700 hover:bg-green-50 hover:text-green-900 transition-colors duration-200"
                                                       data-kt-dropdown-dismiss="true">
                                                        <span class="material-symbols-outlined text-green-500 mr-3 text-lg" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24">print</span>
                                                        Imprimer le rapport
                                                    </a>
                                                }
                                                <hr class="my-1 border-gray-100">
                                                <a asp-action="Details" 
                                                   asp-route-id="@item.Enteteresultatid"
                                                   class="group flex items-center px-4 py-3 text-sm text-gray-700 hover:bg-purple-50 hover:text-purple-900 transition-colors duration-200"
                                                   data-kt-dropdown-dismiss="true">
                                                    <span class="material-symbols-outlined text-purple-500 mr-3 text-lg" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24">visibility</span>
                                                    Voir détails
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        <!-- Empty State -->
        <div id="emptyState" class="hidden text-center py-12">
            <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-gray-100 mb-4">
                <span class="material-symbols-outlined text-gray-400 text-2xl" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 48">search_off</span>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-2">Aucun résultat trouvé</h3>
            <p class="text-gray-500 mb-6">Essayez de modifier vos critères de recherche ou de filtrage.</p>
            <button id="clearFilters" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors duration-200">
                Effacer les filtres
            </button>
        </div>
        
        <!-- Pagination Enhanced -->
        <div class="bg-white px-6 py-4 flex items-center justify-between border-t border-gray-200">
            <div class="flex-1 flex justify-between items-center">
                <div class="text-sm text-gray-700">
                    Affichage de <span class="font-medium" id="startRecord">1</span> à <span class="font-medium" id="endRecord">10</span> 
                    sur <span class="font-medium" id="totalRecords">@Model.Count()</span> résultats
                </div>
                <div class="flex items-center space-x-2">
                    <select class="border border-gray-300 rounded px-3 py-1 text-sm" id="pageSize">
                        <option value="10">10 par page</option>
                        <option value="25">25 par page</option>
                        <option value="50">50 par page</option>
                        <option value="100">100 par page</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Enhanced Modal pour l'affichage du rapport PDF -->
<div id="rapportModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm hidden">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-6xl h-[90vh] flex flex-col m-4">
        <div class="flex justify-between items-center p-6 border-b border-gray-200">
            <div class="flex items-center gap-3">
                <div class="bg-blue-100 p-2 rounded-lg">
                    <span class="material-symbols-outlined text-blue-600">picture_as_pdf</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-gray-900">Aperçu du rapport d'analyse</h2>
                    <p class="text-sm text-gray-500">Prévisualisation avant impression</p>
                </div>
            </div>
            <button id="closeRapportModal" class="bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2 rounded-lg transition-colors duration-200 flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">close</span>
                Fermer
            </button>
        </div>
        <div class="flex-1 overflow-hidden bg-gray-50 p-4">
            <iframe id="rapportPdfFrame" src="" class="w-full h-full border-0 rounded-lg shadow-inner bg-white"></iframe>
        </div>
    </div>
</div>

<!-- Enhanced Loading Spinner -->
<div id="print-spinner" class="fixed inset-0 z-50 hidden" style="display: none; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(4px); pointer-events: none;">
    <div class="absolute inset-0 flex items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-sm mx-4 text-center">
            <div class="mb-4">
                <svg class="animate-spin mx-auto h-12 w-12 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Génération du rapport</h3>
            <p class="text-gray-600 text-sm">Veuillez patienter pendant la préparation de votre document...</p>
            <div class="mt-4 bg-gray-200 rounded-full h-2">
                <div class="bg-blue-500 h-2 rounded-full animate-pulse" style="width: 60%"></div>
            </div>
        </div>
    </div>
</div>

<!-- Loading State for Table -->
<div id="table-loading" class="fixed inset-0 z-40 hidden" style="display: none; background: rgba(255, 255, 255, 0.75); backdrop-filter: blur(2px); pointer-events: none;">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
        <div class="flex flex-col items-center">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-500 mb-4"></div>
            <p class="text-gray-600 font-medium">Chargement des résultats...</p>
        </div>
    </div>
</div>

<!-- Navigation Loading Spinner -->
<div id="navigation-loading" class="fixed inset-0 z-50 hidden" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(4px);">
    <div class="absolute inset-0 flex items-center justify-center">
        <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-sm mx-4 text-center border border-gray-200">
            <div class="mb-6">
                <div class="relative inline-flex">
                    <div class="w-16 h-16 border-4 border-blue-200 border-t-blue-600 rounded-full animate-spin"></div>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <span class="material-symbols-outlined text-blue-600 text-2xl" style="font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24">edit</span>
                    </div>
                </div>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Ouverture de l'éditeur</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Préparation de l'interface d'édition des résultats...</p>
            <div class="mt-6 bg-gray-100 rounded-full h-2">
                <div class="bg-gradient-to-r from-blue-500 to-indigo-600 h-2 rounded-full animate-pulse" style="width: 85%"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script src="~/js/app/enteteresultat/index.js"></script>
    <script>
        $(document).ready(function () {
            console.log('Initializing Enteteresultat page...');
            
            // Initialize the main table functionality
            if (typeof KTEnteteresultatList !== 'undefined') {
                KTEnteteresultatList.init();
            } else {
                console.warn('KTEnteteresultatList not found');
            }
            
            console.log('Enteteresultat page initialized successfully');
        });
    </script>
}
