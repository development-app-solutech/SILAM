@model ProlabWeb.Db.Typepeau

@{
    ViewData["Title"] = "Supprimer un type de peau";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold text-red-600">Supprimer un type de peau</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <div class="flex items-center gap-4 mb-6" style="background:#fee2e2; border:1.5px solid #dc2626; color:#b91c1c; border-radius:0.5rem; padding:1rem;">
        <span class="material-symbols-outlined text-4xl" style="color:#dc2626;">warning</span>
        <div style="color:#b91c1c; font-size:1.125rem; font-weight:600;">
            Êtes-vous vraiment sûr de vouloir supprimer ce type de peau ?<br />
            Cette action est <span class="font-bold">irréversible</span>.
        </div>
    </div>
    <div class="mt-6"></div>
    <div class="bg-gray-50 p-4 rounded-lg mb-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Résumé du type de peau</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="flex flex-col gap-3">
                <div><span class="font-semibold">Code :</span> @Model.Codetypepeau</div>
                <div><span class="font-semibold">Nom :</span> @Model.Nom</div>
                <div><span class="font-semibold">Description :</span> @Model.Description</div>
            </div>
            <div class="flex flex-col gap-3">
                <div><span class="font-semibold">Statut :</span> <span class="@(Model.Isactive ? "kt-badge kt-badge-success kt-badge-outline rounded-[30px]" : "kt-badge kt-badge-destructive kt-badge-outline rounded-[30px]")">@(Model.Isactive ? "Actif" : "Inactif")</span></div>
            </div>
        </div>
    </div>
    <form asp-action="Delete" method="post" class="flex flex-col gap-5">
        <input type="hidden" asp-for="Codetypepeau" />
        <div class="flex justify-end mt-6 space-x-3">
            <a asp-action="Index" class="kt-btn kt-btn-outline mr-4">Annuler</a>
            <button type="submit" class="kt-btn kt-btn-primary bg-red-600 hover:bg-red-700 border-none">Supprimer</button>
        </div>
    </form>
</div>

        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">Confirmation Required</h3>
                    <div class="mt-2 text-sm text-red-700">
                        <p>Are you sure you want to delete this skin type? This action cannot be undone.</p>
    </div>
</div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
                <div class="bg-gray-50 p-4 rounded-lg">
                    <h3 class="text-lg font-medium text-gray-900 mb-3">Basic Information</h3>
                    <dl class="space-y-3">
                        <div>
                            <dt class="text-sm font-medium text-gray-500">@Html.DisplayNameFor(model => model.Codetypepeau)</dt>
                            <dd class="mt-1 text-sm text-gray-900">@Html.DisplayFor(model => model.Codetypepeau)</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">@Html.DisplayNameFor(model => model.Nom)</dt>
                            <dd class="mt-1 text-sm text-gray-900">@Html.DisplayFor(model => model.Nom)</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">@Html.DisplayNameFor(model => model.Description)</dt>
                            <dd class="mt-1 text-sm text-gray-900">@Html.DisplayFor(model => model.Description)</dd>
                        </div>
                    </dl>
                </div>
            </div>

            <div class="space-y-4">
                <div class="bg-gray-50 p-4 rounded-lg">
                    <h3 class="text-lg font-medium text-gray-900 mb-3">Status</h3>
                    <dl class="space-y-3">
                        <div>
                            <dt class="text-sm font-medium text-gray-500">@Html.DisplayNameFor(model => model.Isactive)</dt>
                            <dd class="mt-1">
                                @if (Model.Isactive)
                                {
                                    <span class="inline-block px-2 py-1 text-xs font-semibold text-green-800 bg-green-100 rounded-full">Active</span>
                                }
                                else
                                {
                                    <span class="inline-block px-2 py-1 text-xs font-semibold text-red-800 bg-red-100 rounded-full">Inactive</span>
                                }
                            </dd>
                        </div>
                    </dl>
            </div>
            </div>
            </div>

        <form asp-action="Delete" class="mt-6">
            <input type="hidden" asp-for="Codetypepeau" />
            <div class="flex justify-end space-x-3">
                <a asp-action="Index" class="kt-btn kt-btn-outline mr-4">cancel</a>
                <button type="submit" class="kt-btn kt-btn-danger">Delete</button>
            </div>
            </form>
    </div>
</div>
