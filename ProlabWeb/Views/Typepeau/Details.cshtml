@model ProlabWeb.Db.Typepeau
@{
    ViewData["Title"] = "Détails type de peau";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Détails type de peau</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-5">
            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Informations de base</h3>
                <div class="space-y-2">
                    <div><span class="font-semibold">Code :</span> @Model.Codetypepeau</div>
                    <div><span class="font-semibold">Nom :</span> @Model.Nom</div>
                    <div><span class="font-semibold">Description :</span> @Model.Description</div>
                </div>
            </div>
        </div>
        <div class="flex flex-col gap-5">
            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Statut</h3>
                <div class="space-y-2">
                    <div><span class="font-semibold">Actif :</span> <span class="@(Model.Isactive ? "kt-badge kt-badge-success kt-badge-outline rounded-[30px]" : "kt-badge kt-badge-destructive kt-badge-outline rounded-[30px]")">@(Model.Isactive ? "Actif" : "Inactif")</span></div>
                </div>
            </div>
        </div>
    </div>
    <div class="flex justify-end mt-6 space-x-3">
        <a asp-action="Edit" asp-route-id="@Model?.Codetypepeau" class="kt-btn kt-btn-outline mr-4">Modifier</a>
        <a asp-action="Index" class="kt-btn kt-btn-primary">Retour à la liste</a>
    </div>
</div>

<div class="container-xxl">
    <div class="kt-card p-6 bg-white rounded-xl shadow-md">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-semibold text-mono">Skin Type Details</h1>
            <div class="flex space-x-2">
                <a asp-action="Edit" asp-route-id="@Model?.Codetypepeau" class="kt-btn kt-btn-primary">Edit</a>
                <a asp-action="Index" class="kt-btn kt-btn-outline">Back to List</a>
    </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
                <div class="bg-gray-50 p-4 rounded-lg">
                    <h3 class="text-lg font-medium text-gray-900 mb-3">Basic Information</h3>
                    <dl class="space-y-3">
                        <div>
                            <dt class="text-sm font-medium text-gray-500">@Html.DisplayNameFor(model => model.Codetypepeau)</dt>
                            <dd class="mt-1 text-sm text-gray-900">@Html.DisplayFor(model => model.Codetypepeau)</dd>
    </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">@Html.DisplayNameFor(model => model.Nom)</dt>
                            <dd class="mt-1 text-sm text-gray-900">@Html.DisplayFor(model => model.Nom)</dd>
</div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">@Html.DisplayNameFor(model => model.Description)</dt>
                            <dd class="mt-1 text-sm text-gray-900">@Html.DisplayFor(model => model.Description)</dd>
            </div>
                    </dl>
            </div>
            </div>

            <div class="space-y-4">
                <div class="bg-gray-50 p-4 rounded-lg">
                    <h3 class="text-lg font-medium text-gray-900 mb-3">Status</h3>
                    <dl class="space-y-3">
                        <div>
                            <dt class="text-sm font-medium text-gray-500">@Html.DisplayNameFor(model => model.Isactive)</dt>
                            <dd class="mt-1">
                                @if (Model.Isactive)
                                {
                                    <span class="inline-block px-2 py-1 text-xs font-semibold text-green-800 bg-green-100 rounded-full">Active</span>
                                }
                                else
                                {
                                    <span class="inline-block px-2 py-1 text-xs font-semibold text-red-800 bg-red-100 rounded-full">Inactive</span>
                                }
                            </dd>
            </div>
                    </dl>
            </div>
            </div>
        </div>
    </div>
</div>
