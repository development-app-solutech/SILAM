@model ProlabWeb.Db.Categorie
@{
    ViewData["Title"] = "Détails catégorie";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Détails catégorie</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-5">
            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Informations de base</h3>
                <div class="space-y-2">
                    <div><span class="font-semibold">Nom :</span> @Model.Nom</div>
                    <div><span class="font-semibold">Description :</span> @Model.Description</div>
                    <div><span class="font-semibold">Prix :</span> @Model.Prix</div>
                    <div><span class="font-semibold">Actif :</span> <span class="@(Model.Isactive ? "kt-badge kt-badge-success kt-badge-outline rounded-[30px]" : "kt-badge kt-badge-destructive kt-badge-outline rounded-[30px]")">@(Model.Isactive ? "Actif" : "Inactif")</span></div>
                </div>
            </div>
        </div>
        <div class="flex flex-col gap-5">
            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Analyses associées</h3>
                <div class="flex flex-wrap gap-2">
                    @if (Model.Categorieanalyses != null && Model.Categorieanalyses.Any(ca => ca.IdanalyseNavigation != null))
                    {
                        foreach (var ca in Model.Categorieanalyses)
                        {
                            if (ca.IdanalyseNavigation != null)
                            {
                                <span class="inline-block px-3 py-1 text-xs font-semibold bg-blue-100 text-blue-800 rounded-full">@ca.IdanalyseNavigation.Nom</span>
                            }
                        }
                    }
                    else
                    {
                        <span class="text-gray-500">Aucune analyse associée.</span>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="flex justify-end mt-6 space-x-3">
        <a asp-action="Edit" asp-route-id="@Model?.Categorieid" class="kt-btn kt-btn-outline mr-4">Modifier</a>
        <a asp-action="Index" class="kt-btn kt-btn-primary">Retour à la liste</a>
    </div>
</div> 