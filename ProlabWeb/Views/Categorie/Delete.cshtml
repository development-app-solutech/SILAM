@model ProlabWeb.Db.Categorie

@{
    ViewData["Title"] = "Supprimer une catégorie";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold text-red-600">Supprimer une catégorie</h1>
        </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
                    </div>
                </div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
            </div>
<div class="min-w-full mb-5">
    <div class="flex items-center gap-4 mb-6" style="background:#fee2e2; border:1.5px solid #dc2626; color:#b91c1c; border-radius:0.5rem; padding:1rem;">
        <span class="material-symbols-outlined text-4xl" style="color:#dc2626;">warning</span>
        <div style="color:#b91c1c; font-size:1.125rem; font-weight:600;">
            Êtes-vous vraiment sûr de vouloir supprimer cette catégorie ?<br />
            Cette action est <span class="font-bold">irréversible</span>.
        </div>
                    </div>
    <div class="mt-6"></div>
    <div class="bg-gray-50 p-4 rounded-lg mb-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Résumé de la catégorie</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="flex flex-col gap-3">
                <div><span class="font-semibold">Nom :</span> @Model.Nom</div>
                <div><span class="font-semibold">Description :</span> @Model.Description</div>
                <div><span class="font-semibold">Prix :</span> @Model.Prix</div>
            </div>
            <div class="flex flex-col gap-3">
                <div><span class="font-semibold">Statut :</span> <span class="@(Model.Isactive ? "kt-badge kt-badge-success kt-badge-outline rounded-[30px]" : "kt-badge kt-badge-destructive kt-badge-outline rounded-[30px]")">@(Model.Isactive ? "Actif" : "Inactif")</span></div>
            </div>
        </div>
    </div>
    <form asp-action="Delete" method="post" class="flex flex-col gap-5">
        <input type="hidden" asp-for="Categorieid" />
        <div class="flex justify-end mt-6 space-x-3">
            <a asp-action="Index" class="kt-btn kt-btn-outline mr-4">Annuler</a>
            <button type="submit" class="kt-btn kt-btn-primary bg-red-600 hover:bg-red-700 border-none">Supprimer</button>
            </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
