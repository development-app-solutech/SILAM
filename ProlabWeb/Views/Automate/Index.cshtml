@model IEnumerable<ProlabWeb.Db.Automate>
@{
    ViewData["Title"] = "Automates";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Liste des automates</h1>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full">
    <div class="grid gap-5">
        <div class="grid grid-cols-3 gap-5 mb-4">
            <div>
                <label class="kt-input border-t border-primary">
                    <span class="material-symbols-outlined">search</span>
                    <input class="kt-input" placeholder="Recherche" type="text" id="search-automate" data-kt-automate-table-filter="search">
                </label>
            </div>
            <div></div>
            <div class="inline-flex justify-end grow gap-5">
                <a asp-action="Create" class="kt-btn kt-btn-primary">
                    <span class="material-symbols-outlined align-middle">add</span> Nouvel automate
                </a>

            </div>
        </div>
        <div id="kt_spinner_automate_index" style="visibility:hidden;">
            <span class="spinner-border spinner-border-sm"></span> Chargement...
        </div>
        <div class="kt-scrollable-x-auto">
            <form method="post">
                @Html.AntiForgeryToken()
                <table id="kt_table_automate_index" class="kt-table table-auto kt-table-border min-w-full">
                    <thead>
                        <tr>
                            <th><span class="kt-table-col-label font-bold">@Html.DisplayNameFor(model => model.Nom)</span></th>
                            <th><span class="kt-table-col-label font-bold">@Html.DisplayNameFor(model => model.Description)</span></th>
                            <th><span class="kt-table-col-label font-bold">@Html.DisplayNameFor(model => model.Isactive)</span></th>
                            <th class="w-[60px]"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="font-normal text-foreground">@Html.DisplayFor(modelItem => item.Nom)</td>
                                <td class="font-normal text-foreground">@Html.DisplayFor(modelItem => item.Description)</td>
                                <td>
                                    @if (item.Isactive)
                                    {
                                        <span class="kt-badge kt-badge-success kt-badge-outline rounded-[30px]">
                                            <span class="kt-badge-dot size-1.5"></span>
                                            Actif
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="kt-badge kt-badge-destructive kt-badge-outline rounded-[30px]">
                                            <span class="kt-badge-dot size-1.5"></span>
                                            Inactif
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="kt-menu flex-inline" data-kt-menu="true">
                                        <div class="kt-menu-item kt-menu-item-dropdown" data-kt-menu-item-offset="0, 10px" data-kt-menu-item-placement="bottom-end" data-kt-menu-item-placement-rtl="bottom-start" data-kt-menu-item-toggle="dropdown" data-kt-menu-item-trigger="click">
                                            <button class="kt-menu-toggle kt-btn kt-btn-sm kt-btn-icon kt-btn-ghost">
                                                <i class="ki-filled ki-dots-vertical text-lg"></i>
                                            </button>
                                            <div class="kt-menu-dropdown kt-menu-default w-full max-w-[175px]" data-kt-menu-dismiss="true">
                                                <div class="kt-menu-item">
                                                    <a class="kt-menu-link" asp-action="Edit" asp-route-id="@item.Idautomate">
                                                        <span class="kt-menu-icon"><i class="ki-filled ki-pencil"></i></span>
                                                        <span class="kt-menu-title">Modifier</span>
                                                    </a>
                                                </div>
                                                <div class="kt-menu-item">
                                                    <a class="kt-menu-link" asp-action="Details" asp-route-id="@item.Idautomate">
                                                        <span class="kt-menu-icon"><i class="ki-filled ki-eye"></i></span>
                                                        <span class="kt-menu-title">Détails</span>
                                                    </a>
                                                </div>
                                                @* <div class="kt-menu-item">
                                                    <a href="#" class="kt-menu-link" data-kt-automates-table-filter="delete_row" data-id="@item.Idautomate">
                                                        <span class="kt-menu-icon"><i class="ki-filled ki-trash"></i></span>
                                                        <span class="kt-menu-title">Supprimer</span>
                                                    </a>
                                                </div> *@
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/app/automate/index.js"></script>
    <script>
        $(document).ready(function() {
            @if (TempData["AutomateCree"] != null)
            {
                <text>
                var msg = @Html.Raw(Json.Serialize(TempData["AutomateCree"]));
                Swal.fire({
                    icon: 'success',
                    title: 'Succès',
                    html: msg,
                    confirmButtonText: 'OK'
                });
                </text>
            }
            @if (TempData["AutomateModifie"] != null)
            {
                <text>
                var msgModif = @Html.Raw(Json.Serialize(TempData["AutomateModifie"]));
                if (msgModif === "success") {
                    Swal.fire({
                        icon: 'success',
                        title: 'Succès',
                        text: 'Modifications enregistrées avec succès',
                        confirmButtonText: 'OK'
                    });
                } else if (msgModif === "error") {
                    Swal.fire({
                        icon: 'error',
                        title: 'Erreur',
                        text: "Une erreur est survenue. Les modifications n'ont pas été enregistrées",
                        confirmButtonText: 'OK'
                    });
                }
                </text>
            }
        });
    </script>
}