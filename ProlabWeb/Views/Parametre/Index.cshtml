@model IEnumerable<ProlabWeb.Db.Parametre>

@{
    ViewData["Title"] = "Paramétres";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Liste des Paramètres</h1>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full">
    <div class="grid gap-5">
        <div class="grid grid-cols-3 gap-5 mb-4">
            <div>
                <label class="kt-input border-t border-primary">
                    <span class="material-symbols-outlined">
                        search
                    </span>
                    <input class="kt-input" placeholder="Recherche" type="text" data-kt-parametre-table-filter="search"
                        id="search-parametre">
                </label>
            </div>
            <div></div>
            <div class="inline-flex justify-end grow gap-5">
                <a asp-action="Create" class="kt-btn kt-btn-primary">
                    <span class="material-symbols-outlined align-middle">add</span> Nouveau paramètre
                </a>

            </div>
        </div>
        <div class="kt-scrollable-x-auto mb-5">
            <table class="kt-table table-auto kt-table-border min-w-full" id="kt_table_parametre_index">
                <thead>
                    <tr>
                        <th><span class="kt-table-col-label font-bold">Analyse</span></th>
                        <th><span class="kt-table-col-label font-bold">Nom</span></th>
                        <th><span class="kt-table-col-label font-bold">Code</span></th>
                        <th><span class="kt-table-col-label font-bold">Masquer</span></th>
                        <th><span class="kt-table-col-label font-bold">Formule</span></th>
                        <th><span class="kt-table-col-label font-bold">Unité Standard</span></th>
                        <th><span class="kt-table-col-label font-bold">Unité SI</span></th>
                        <th><span class="kt-table-col-label font-bold">Décimales Résultat Standard</span></th>
                        <th><span class="kt-table-col-label font-bold">Décimales Résultat SI</span></th>
                        <th><span class="kt-table-col-label font-bold">Facteur Conversion</span></th>
                        <th><span class="kt-table-col-label font-bold">Ordre Affichage</span></th>
                        <th><span class="kt-table-col-label font-bold">Value builder</span></th>
                        <th class="w-[60px]"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="font-normal text-foreground">
                                @if (item.IdanalyseNavigation != null)
                                {
                                    @item.IdanalyseNavigation.Nom
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="font-normal text-foreground">@item.Nom</td>
                            <td class="font-normal text-foreground">@item.Code</td>
                            <td class="font-normal text-foreground">@(item.Masquerdansrapport ? "Oui" : "Non")</td>
                            <td class="font-normal text-foreground">@item.Formuleautomate</td>
                            <td class="font-normal text-foreground">@(item.CodeuniteNavigation?.Name ?? item.Codeunite)</td>
                            <td class="font-normal text-foreground">@(item.CodeunitesiNavigation?.Name ?? item.Codeunitesi)</td>
                            <td class="font-normal text-foreground">@item.Decimalresultatstandard</td>
                            <td class="font-normal text-foreground">@item.Decimalresultatsi</td>
                            <td class="font-normal text-foreground">@item.Facteurconversionsi</td>
                            <td class="font-normal text-foreground">@item.Ordreaffichage</td>
                            <td class="font-normal text-foreground">@item.Valuebuilder</td>
                            <td class="text-center">
                                <div class="kt-menu flex-inline" data-kt-menu="true">
                                    <div class="kt-menu-item kt-menu-item-dropdown" data-kt-menu-item-offset="0, 10px"
                                        data-kt-menu-item-placement="bottom-end"
                                        data-kt-menu-item-placement-rtl="bottom-start" data-kt-menu-item-toggle="dropdown"
                                        data-kt-menu-item-trigger="click">
                                        <button class="kt-menu-toggle kt-btn kt-btn-sm kt-btn-icon kt-btn-ghost">
                                            <i class="ki-filled ki-dots-vertical text-lg"></i>
                                        </button>
                                        <div class="kt-menu-dropdown kt-menu-default w-full max-w-[175px]"
                                            data-kt-menu-dismiss="true">
                                            <div class="kt-menu-item">
                                                <a class="kt-menu-link" asp-action="Edit" asp-route-id="@item.Idanalyse">
                                                    <span class="kt-menu-icon"><i class="ki-filled ki-pencil"></i></span>
                                                    <span class="kt-menu-title">Modifier</span>
                                                </a>
                                            </div>
                                            <div class="kt-menu-item">
                                                <a class="kt-menu-link" asp-action="Details"
                                                    asp-route-id="@item.Parametreid">
                                                    <span class="kt-menu-icon"><i class="ki-filled ki-eye"></i></span>
                                                    <span class="kt-menu-title">Détails</span>
                                                </a>
                                            </div>
                                            @* <div class="kt-menu-item">
                                                <a class="kt-menu-link" asp-action="Delete"
                                                    asp-route-id="@item.Parametreid">
                                                    <span class="kt-menu-icon"><i class="ki-filled ki-trash"></i></span>
                                                    <span class="kt-menu-title">Supprimer</span>
                                                </a>
                                            </div> *@
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

@section Scripts {
            <script>
                $(document).ready(function () {
                    var table = $('#kt_table_parametre_index').DataTable({
                        searching: true,
                        ordering: true,
                        paging: true,
                        pageLength: 10,
                        dom: 'rtip', // Remove default search box (f) and length menu (l)
                        language: {
                            emptyTable: "Aucune donnée à afficher",
                            zeroRecords: "Aucun résultat trouvé",
                            info: "Affichage de _START_ à _END_ sur _TOTAL_ éléments",
                            infoEmpty: "Affichage de 0 à 0 sur 0 élément",
                            infoFiltered: "(filtré à partir de _MAX_ éléments au total)",
                            paginate: {
                                first: "Premier",
                                last: "Dernier",
                                next: "Suivant",
                                previous: "Précédent"
                            }
                        }
                    });
                    
                    // Use custom search input
                    $('[data-kt-parametre-table-filter="search"]').on('keyup', function () {
                        table.search(this.value).draw();
                    });
                    @if (TempData["ParametreCree"] != null)
                        {
                            <text>
                                var msg = @Html.Raw(Json.Serialize(TempData["ParametreCree"]));
                                console.log('TempData ParametreCree :', msg);
                                Swal.fire({
                                    icon: 'success',
                                title: 'Succès',
                                html: msg,
                                confirmButtonText: 'OK'
                        });
                            </text>
                    }
                        @if (TempData["ParametreModifie"] != null)
                        {
                            <text>
                                var msgModif = @Html.Raw(Json.Serialize(TempData["ParametreModifie"]));
                                if (msgModif === "success") {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Succès',
                                        text: 'Modifications enregistrées avec succès',
                                        confirmButtonText: 'OK'
                                    });
                        } else if (msgModif === "error") {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Erreur',
                                        text: "Une erreur est survenue. Les modifications n'ont pas été enregistrées",
                                        confirmButtonText: 'OK'
                                    });
                        }
                            </text>
                    }
            });
            </script>
}
