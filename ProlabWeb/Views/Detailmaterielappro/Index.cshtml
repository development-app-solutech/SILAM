                @Html.DisplayNameFor(model => model.Entetematerielappro)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Materiel)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
