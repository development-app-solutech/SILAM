@model ProlabWeb.Db.Policeassurance

@{
    ViewData["Title"] = "Détails police d'assurance";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Détails police d'assurance</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-5">
            <div class="bg-gray-50 p-4 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Informations de la police</h3>
                <div class="space-y-2">
                    <div><span class="font-semibold">Libellé :</span> @Model.Libelle</div>
                    <div><span class="font-semibold">Taux :</span> @Model.Taux</div>
                    <div><span class="font-semibold">Assurance :</span> @Model.CodeassuranceNavigation?.Nom</div>
                </div>
            </div>
        </div>
    </div>
    <div class="flex justify-end mt-6 space-x-3">
        <a asp-action="Edit" asp-route-id="@Model?.Policeassuranceid" class="kt-btn kt-btn-outline mr-4">Modifier</a>
        <a asp-action="Index" class="kt-btn kt-btn-primary">Retour à la liste</a>
    </div>
</div>
