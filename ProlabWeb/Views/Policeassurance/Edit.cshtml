@model ProlabWeb.ViewModels.PoliceassuranceEditVM

@{
    ViewData["Title"] = "Modifier une police d'assurance";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Modifier une police d'assurance</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <form asp-action="Edit" method="post" class="flex flex-col gap-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Policeassuranceid" />
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
        {
            <div class="alert alert-danger">
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }
        <div asp-validation-summary="ModelOnly" class="text-red-500"></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="flex flex-col gap-5">
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Codeassurance"></label>
                    <select class="kt-input" asp-for="Codeassurance" asp-items="@(ViewData["Codeassurance"] as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)">
                        <option value="">-- Sélectionner une assurance --</option>
                    </select>
                    <span asp-validation-for="Codeassurance" class="text-red-500"></span>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Libelle"></label>
                    <input class="kt-input" asp-for="Libelle" placeholder="Libellé" type="text">
                    <span asp-validation-for="Libelle" class="text-red-500"></span>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Taux"></label>
                    <input class="kt-input" asp-for="Taux" placeholder="Taux (%)" type="number" step="0.01">
                    <span asp-validation-for="Taux" class="text-red-500"></span>
                </div>
            </div>
        </div>
        <div class="inline-flex justify-start grow">
            <button type="submit" class="kt-btn kt-btn-primary">
                <span class="material-symbols-outlined">
                    save
                </span> Enregistrer
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
