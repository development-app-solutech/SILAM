@model ProlabWeb.ViewModels.AffectationcaisseEditVM

@{
    ViewData["Title"] = "Modifier une affectation caisse";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-2">
    <div>
        <h1 class="font-bold">Modifier une affectation caisse</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-4">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <form asp-action="Edit" method="post" data-redirect="/Affectationcaisse" class="flex flex-col gap-5">
        @Html.AntiForgeryToken()
        <div id="validation-errors" style="display: none;" class="text-red-500 mb-4"></div>
        <input type="hidden" asp-for="Affectationcaisseid" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="flex flex-col gap-5">
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Caisseid"></label>
                    <select class="kt-input" asp-for="Caisseid" asp-items="ViewBag.Caisseid">
                        <option value="">-- Sélectionner une caisse --</option>
                    </select>
                    <span asp-validation-for="Caisseid" class="text-red-500"></span>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Utilisateurid"></label>
                    <select class="kt-input" asp-for="Utilisateurid" asp-items="ViewBag.Utilisateurid">
                        <option value="">-- Sélectionner un caissier --</option>
                    </select>
                    <span asp-validation-for="Utilisateurid" class="text-red-500"></span>
                </div>
                <div class="flex flex-col gap-3">
                    <label class="kt-form-label text-mono" asp-for="Date"></label>
                    <input class="kt-input" asp-for="Date" type="date" />
                    <span asp-validation-for="Date" class="text-red-500"></span>
                </div>
            </div>
        </div>
        <div class="inline-flex justify-start grow">
            <button type="submit" class="kt-btn kt-btn-primary">
                <span class="material-symbols-outlined">
                    save
                </span> Enregistrer
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    @if (TempData["ValidationErrors"] != null)
    {
        <script>
            $(document).ready(function() {
                var serverErrors = @Html.Raw(Json.Serialize(TempData["ValidationErrors"]));
                if (serverErrors && serverErrors.length > 0) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Erreur de contrainte',
                        html: '<ul style="text-align:left;margin:0;padding-left:20px;">' + serverErrors.map(function(e) { return '<li>' + e + '</li>'; }).join('') + '</ul>',
                        confirmButtonText: 'OK'
                    });
                }
            });
        </script>
    }
    
    <script>
        $(document).ready(function() {
            console.log('Edit form loaded');
            
            var form = $('form[asp-action="Edit"]');
            var submitBtn = $('#submit-btn');

            form.on('submit', function(e) {
                e.preventDefault();
                
                var formData = form.serialize();
                
                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    beforeSend: function() {
                        submitBtn.prop('disabled', true).text('Modification...');
                    },
                    success: function(response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Succès',
                                text: 'Affectation modifiée avec succès !',
                                confirmButtonText: 'OK'
                            }).then(function() {
                                window.location.href = '/Affectationcaisse';
                            });
                        } else if (response.errors) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Erreur de contrainte',
                                html: '<ul style="text-align:left;margin:0;padding-left:20px;">' + response.errors.map(function(e) { return '<li>' + e + '</li>'; }).join('') + '</ul>',
                                confirmButtonText: 'OK'
                            });
                        }
                    },
                    error: function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'Erreur',
                            text: 'Une erreur est survenue lors de la modification.',
                            confirmButtonText: 'OK'
                        });
                    },
                    complete: function() {
                        submitBtn.prop('disabled', false).text('Enregistrer');
                    }
                });
            });
        });
    </script>
}
