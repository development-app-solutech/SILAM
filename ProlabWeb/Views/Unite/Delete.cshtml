@model ProlabWeb.Db.Unite

@{
    ViewData["Title"] = "Delete";
}

<div class="kt-card p-6 bg-white rounded-xl shadow-md max-w-lg">
    <h1 class="text-2xl font-semibold text-mono mb-2">Suppression Unite</h1>
    <h3 class="text-lg font-medium mb-4 text-danger">Are you sure you want to delete this?</h3>
    <h4 class="text-lg font-medium mb-4">Unite</h4>
    <hr class="mb-4" />
    <dl class="grid grid-cols-3 gap-y-4 gap-x-2 mb-6">
        <dt class="font-medium text-gray-600">@Html.DisplayNameFor(model => model.Name)</dt>
        <dd class="col-span-2">@Html.DisplayFor(model => model.Name)</dd>
        <dt class="font-medium text-gray-600">@Html.DisplayNameFor(model => model.Isage)</dt>
        <dd class="col-span-2">@Html.DisplayFor(model => model.Isage)</dd>
        <dt class="font-medium text-gray-600">@Html.DisplayNameFor(model => model.Isageday)</dt>
        <dd class="col-span-2">@Html.DisplayFor(model => model.Isageday)</dd>
    </dl>
    <form asp-action="Delete" class="flex items-center gap-2 mt-4">
        <input type="hidden" asp-for="Code" />
        <input type="submit" value="Delete" class="kt-btn kt-btn-danger" />
        <a asp-action="Index" class="kt-btn kt-btn-light">Back to List</a>
    </form>
</div>
