@model ProlabWeb.Db.Caisse

@{
    ViewData["Title"] = "Suppression caisse";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5 mb-5">
    <div>
        <h1 class="font-bold">Suppression caisse</h1>
    </div>
    <div class="text-end">
        <a asp-action="Index" class="text-primary">Retour à la liste</a>
    </div>
</div>
<div class="flex items-center gap-2 mb-5">
    <span class="border-t border-border border-primary w-full"></span>
</div>
<div class="min-w-full mb-5">
    <div class="kt-card p-5">
        <h3 class="text-danger mb-3">Êtes-vous sûr de vouloir supprimer cette caisse ?</h3>
        <dl class="grid grid-cols-2 gap-5">
            <dt class="font-semibold">Nom</dt>
            <dd>@Model.Nom</dd>
            <dt class="font-semibold">Site</dt>
            <dd>@Model.CodesiteNavigation?.Name</dd>
            <dt class="font-semibold">Active</dt>
            <dd>@(Model.Isactive ? "Oui" : "Non")</dd>
        </dl>
        <form asp-action="Delete" method="post" class="flex gap-3 mt-5">
            <input type="hidden" asp-for="Caisseid" />
            <input type="submit" value="Supprimer" class="kt-btn kt-btn-danger" />
            <a asp-action="Index" class="kt-btn kt-btn-secondary">Annuler</a>
        </form>
    </div>
</div>
