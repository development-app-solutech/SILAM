@model IEnumerable<ProlabWeb.Db.Caisse>

@{
    ViewData["Title"] = "Liste des caisses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="grid grid-cols-2 gap-5">
    <div>
        <h1 class="font-bold">Liste des caisses</h1>
    </div>
</div>
<div class="flex items-center gap-2">
    <span class="border-t border-border border-primary w-full"></span>
</div>

<div class="min-w-full">
    <div class="grid gap-5" data-kt-datatable="true" data-kt-datatable-page-size="10">
        <div class="grid grid-cols-3 gap-5 mb-4">
            <div>
                <label class="kt-input border-t border-primary">
                    <span class="material-symbols-outlined">search</span>
                    <input class="kt-input" placeholder="Recherche" type="text" data-kt-caisse-table-filter="search" id="search-caisse">
                </label>
            </div>
            <div></div>
            <div class="inline-flex justify-end grow gap-5">
                <a asp-action="Create" class="kt-btn kt-btn-primary">
                    <span class="material-symbols-outlined">add</span> Nouvelle caisse
                </a>

            </div>
        </div>
        <div class="kt-scrollable-x-auto">
            <table id="kt_table_caisse_index" class="kt-table table-auto kt-table-border">
                <thead>
                    <tr>
                        <th class="w-[60px]">
                            <input class="kt-checkbox kt-checkbox-sm" data-kt-datatable-check="true" type="checkbox">
                        </th>
                        <th><span class="kt-table-col"><span class="kt-table-col-label">Active</span></span></th>
                        <th><span class="kt-table-col"><span class="kt-table-col-label">Nom</span></span></th>
                        <th><span class="kt-table-col"><span class="kt-table-col-label">Site</span></span></th>
                        <th class="w-[60px]"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-start">
                                <input class="kt-checkbox kt-checkbox-sm" data-kt-datatable-row-check="true" type="checkbox" value="1">
                            </td>
                            <td>
                                @if (item.Isactive)
                                {
                                    <span class="kt-badge kt-badge-success kt-badge-outline rounded-[30px]">
                                        <span class="kt-badge-dot size-1.5"></span>
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="kt-badge kt-badge-destructive kt-badge-outline rounded-[30px]">
                                        <span class="kt-badge-dot size-1.5"></span>
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td class="font-normal text-foreground">@item.Nom</td>
                            <td class="font-normal text-foreground">@item.CodesiteNavigation?.Name</td>
                            <td class="text-center">
                                <div class="kt-menu flex-inline" data-kt-menu="true">
                                    <div class="kt-menu-item kt-menu-item-dropdown" data-kt-menu-item-offset="0, 10px" data-kt-menu-item-placement="bottom-end" data-kt-menu-item-placement-rtl="bottom-start" data-kt-menu-item-toggle="dropdown" data-kt-menu-item-trigger="click">
                                        <button class="kt-menu-toggle kt-btn kt-btn-sm kt-btn-icon kt-btn-ghost">
                                            <i class="ki-filled ki-dots-vertical text-lg"></i>
                                        </button>
                                        <div class="kt-menu-dropdown kt-menu-default w-full max-w-[175px]" data-kt-menu-dismiss="true">
                                            <div class="kt-menu-item">
                                                <a class="kt-menu-link" asp-action="Edit" asp-route-id="@item.Caisseid">
                                                    <span class="kt-menu-icon">
                                                        <i class="ki-filled ki-pencil"></i>
                                                    </span>
                                                    <span class="kt-menu-title">Modifier</span>
                                                </a>
                                            </div>
                                            <div class="kt-menu-item">
                                                <a class="kt-menu-link" asp-action="Details" asp-route-id="@item.Caisseid">
                                                    <span class="kt-menu-icon">
                                                        <i class="ki-filled ki-search-list"></i>
                                                    </span>
                                                    <span class="kt-menu-title">Détail</span>
                                                </a>
                                            </div>
                                            @* <div class="kt-menu-item">
                                                <a class="kt-menu-link" asp-action="Delete" asp-route-id="@item.Caisseid">
                                                    <span class="kt-menu-icon">
                                                        <i class="ki-filled ki-trash"></i>
                                                    </span>
                                                    <span class="kt-menu-title">Supprimer</span>
                                                </a>
                                            </div> *@
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/app/caisse/index.js"></script>
}


